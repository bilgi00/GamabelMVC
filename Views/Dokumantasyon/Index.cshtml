<script>
    function toggleSection(header) {
        var body = header.nextElementSibling;
        body.classList.toggle('collapsed');
        var badge = header.querySelector('.badge');
        if (body.classList.contains('collapsed')) {
            badge.textContent = '▶ Aç';
            badge.className = 'badge bg-secondary';
        } else {
            var original = header.dataset.originalBadge || badge.textContent;
            if (!header.dataset.originalBadge) header.dataset.originalBadge = badge.textContent;
            badge.textContent = original;
            badge.className = header.dataset.originalClass || badge.className;
            if (!header.dataset.originalClass) header.dataset.originalClass = badge.className;
        }
    }
    // Store original badges
    document.querySelectorAll('.doc-section-header').forEach(function(h) {
        var b = h.querySelector('.badge');
        h.dataset.originalBadge = b.textContent;
        h.dataset.originalClass = b.className;
    });
</script>

