@{
    ViewData["Title"] = "Proje Dokümantasyonu";
}

<style>
    .doc-container { max-width: 1100px; margin: 0 auto; padding: 20px; }
    .doc-header { background: linear-gradient(135deg, #1a237e, #283593); color: white; padding: 30px; border-radius: 12px; margin-bottom: 30px; }
    .doc-header h2 { margin: 0; font-weight: 700; }
    .doc-header p { margin: 5px 0 0; opacity: 0.85; font-size: 14px; }
    .doc-section { background: white; border: 1px solid #dee2e6; border-radius: 10px; margin-bottom: 20px; overflow: hidden; }
    .doc-section-header { background: #f8f9fa; padding: 14px 20px; border-bottom: 1px solid #dee2e6; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .doc-section-header h5 { margin: 0; font-weight: 600; color: #1a237e; }
    .doc-section-header .badge { font-size: 11px; }
    .doc-section-body { padding: 20px; }
    .doc-section-body.collapsed { display: none; }
    .page-card { background: #f8f9fa; border-radius: 8px; padding: 15px; margin-bottom: 12px; border-left: 4px solid #1a237e; }
    .page-card h6 { color: #1a237e; font-weight: 700; margin-bottom: 8px; }
    .page-card p { margin: 0; font-size: 13px; color: #555; line-height: 1.6; }
    .page-card .endpoint { font-family: monospace; font-size: 12px; background: #e8eaf6; padding: 2px 8px; border-radius: 4px; color: #283593; display: inline-block; margin: 2px 0; }
    .page-card .table-badge { font-size: 11px; background: #e3f2fd; color: #1565c0; padding: 2px 8px; border-radius: 4px; display: inline-block; margin: 1px 2px; }
    .tree-container { font-family: 'Consolas', 'Courier New', monospace; font-size: 13px; background: #1e1e2e; color: #cdd6f4; padding: 20px; border-radius: 10px; line-height: 1.8; }
    .tree-container .folder { color: #89b4fa; font-weight: bold; }
    .tree-container .file-cs { color: #a6e3a1; }
    .tree-container .file-cshtml { color: #f9e2af; }
    .tree-container .file-json { color: #fab387; }
    .tree-container .file-css { color: #f38ba8; }
    .tree-container .file-js { color: #cba6f7; }
    .tree-container .arrow { color: #6c7086; }
    .oneri-card { background: white; border: 1px solid #dee2e6; border-radius: 10px; padding: 16px 20px; margin-bottom: 10px; display: flex; align-items: flex-start; gap: 14px; }
    .oneri-no { background: #dc3545; color: white; border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; flex-shrink: 0; }
    .oneri-no.medium { background: #fd7e14; }
    .oneri-no.low { background: #0d6efd; }
    .oneri-content h6 { margin: 0 0 4px; font-weight: 600; }
    .oneri-content p { margin: 0; font-size: 13px; color: #555; }
    .severity-badge { font-size: 10px; padding: 2px 8px; border-radius: 4px; font-weight: 600; }
    .severity-critical { background: #f8d7da; color: #842029; }
    .severity-high { background: #fff3cd; color: #664d03; }
    .severity-medium { background: #cff4fc; color: #055160; }
    .conn-diagram { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; padding: 10px; }
    .conn-node { background: #e8eaf6; border: 2px solid #3949ab; border-radius: 10px; padding: 10px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #1a237e; min-width: 120px; }
    .conn-node.view-node { background: #fff8e1; border-color: #f9a825; color: #e65100; }
    .conn-node.model-node { background: #e8f5e9; border-color: #43a047; color: #1b5e20; }
    .conn-node.service-node { background: #fce4ec; border-color: #e91e63; color: #880e4f; }
    .conn-arrow { display: flex; align-items: center; color: #9e9e9e; font-size: 20px; }
    .db-table { font-family: monospace; font-size: 12px; background: #263238; color: #80cbc4; padding: 3px 8px; border-radius: 4px; display: inline-block; margin: 1px 2px; }
    .flow-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-top: 12px; }
    .flow-card { background: linear-gradient(180deg, #ffffff, #f8f9fa); border: 1px solid #d7dee8; border-radius: 10px; padding: 14px; min-height: 150px; position: relative; }
    .flow-card h6 { margin: 0 0 8px; color: #1a237e; font-weight: 700; font-size: 14px; }
    .flow-card p { margin: 0; font-size: 12px; color: #495057; line-height: 1.55; }
    .flow-time { display: inline-block; margin-bottom: 8px; background: #1a237e; color: white; border-radius: 999px; padding: 3px 10px; font-size: 11px; font-weight: 700; }
    .flow-arrow-row { display: flex; align-items: center; justify-content: center; margin: 10px 0 2px; color: #6c757d; font-size: 22px; }
</style>

