@model List<gamabelmvc.Models.PRS.SikayetModel>
@{
    ViewBag.Title = "Şikayet Yönetimi";
}
<h2>Şikayet Yönetimi (Admin)</h2>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Tarih</th>
            <th>Kullanıcı</th>
            <th>Konu</th>
            <th>Detay</th>
            <th>Durum</th>
            <th>Sonuç</th>
            <th>Sonuç Tarihi</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr class="@(s.Durum == "Açık" ? "table-warning" : "table-success")">
                <td>@s.Tarih.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@s.KullaniciAdi</td>
                <td>@s.Konu</td>
                <td>@s.Detay</td>
                <td>
                    @if (s.Durum == "Açık")
                    {
                        <span class="badge bg-warning text-dark">Açık</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Kapalı</span>
                    }
                </td>
                <td>@s.Sonuc</td>
                <td>@(s.SonucTarihi?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                <td>
                    @if (s.Durum == "Açık")
                    {
                        <form method="post" action="/Sikayet/SonucKaydet" style="min-width:180px;">
                            <input type="hidden" name="id" value="@s.Id" />
                            <div class="mb-1">
                                <input type="text" name="sonuc" class="form-control form-control-sm" placeholder="Çözüm/sonuç yaz..." required />
                            </div>
                            <div class="mb-1">
                                <select name="durum" class="form-select form-select-sm" required>
                                    <option value="Kapalı">Kapandı</option>
                                    <option value="Çözüldü">Çözüldü</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-sm btn-success w-100">Kaydet</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Success"]</div>
    <script>setTimeout(()=>location.reload(), 1200);</script>
}