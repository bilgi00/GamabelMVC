@model List<gamabelmvc.Models.PRS.OtFirma>
@{
    ViewData["Title"] = "Firma Yönetimi";
}

<style>
    .ot-header { background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; padding: 18px 22px; border-radius: 12px 12px 0 0; }
    .ot-card { background: white; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.1); overflow: hidden; margin-bottom: 24px; }
    .ot-card-body { padding: 20px; }
    .ot-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; font-size: 13px; font-weight: 600; border-radius: 8px; text-decoration: none; border: none; cursor: pointer; transition: all 0.2s; }
    .ot-btn-primary { background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; }
    .ot-btn-danger { background: #dc3545; color: white; }
    .ot-btn-secondary { background: #6c757d; color: white; }
    .ot-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .ot-table th { background: #f1f5f9; padding: 8px 12px; text-align: left; font-weight: 600; border-bottom: 2px solid #dee2e6; }
    .ot-table td { padding: 8px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
    .ot-table tbody tr:hover { background: #f8f9fa; }
    .form-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; padding: 16px; background: #f8faff; border-radius: 8px; margin-bottom: 20px; border: 1px solid #dbeafe; }
    .form-row input { padding: 7px 12px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 13px; }
    .form-row label { font-size: 12px; font-weight: 600; color: #374151; display: block; margin-bottom: 4px; }
    .alert-hata { background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; }
</style>

<div style="margin-bottom:12px;">
    <a href="/OdemeTalimat" class="ot-btn ot-btn-secondary">← Ödeme Talimatlarına Dön</a>
</div>

<div class="ot-card">
    <div class="ot-header">
        <h1 style="font-size:18px; margin:0;">🏢 Firma Yönetimi</h1>
    </div>
    <div class="ot-card-body">

        @if (TempData["Hata"] != null)
        {
            <div class="alert-hata">❌ @TempData["Hata"]</div>
        }

        <!-- Yeni Firma Ekleme Formu -->
        <form method="post" asp-controller="OdemeTalimat" asp-action="FirmaKaydet">
            <input type="hidden" name="Id" value="0" />
            <div class="form-row">
                <div>
                    <label>Cari İsmi (Faturadaki isim) *</label>
                    <input type="text" name="CariIsmi" required placeholder="örn: ABC TİCARET A.Ş." style="width:220px;" />
                </div>
                <div>
                    <label>Ödeme İsmi (Alıcı adı)</label>
                    <input type="text" name="OdemeIsmi" placeholder="IBAN sahibi isim" style="width:220px;" />
                </div>
                <div>
                    <label>IBAN *</label>
                    <input type="text" name="IBAN" required placeholder="TR..." maxlength="26" style="width:230px; font-family:monospace;" />
                </div>
                <div>
                    <label>Açıklama</label>
                    <input type="text" name="Aciklama" placeholder="(opsiyonel)" style="width:160px;" />
                </div>
                <div>
                    <button type="submit" class="ot-btn ot-btn-primary">➕ Ekle</button>
                </div>
            </div>
        </form>

        <!-- Firma Listesi -->
        @if (!Model.Any())
        {
            <p style="color:#6c757d; font-size:13px;">Henüz firma tanımlı değil.</p>
        }
        else
        {
            <table class="ot-table">
                <thead>
                    <tr>
                        <th>Cari İsmi</th>
                        <th>Ödeme İsmi</th>
                        <th>IBAN</th>
                        <th>Açıklama</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model)
                    {
                        <tr>
                            <td>@f.CariIsmi</td>
                            <td>@f.OdemeIsmi</td>
                            <td style="font-family:monospace; font-size:12px;">@f.IBAN</td>
                            <td style="color:#6c757d;">@(f.Aciklama ?? "—")</td>
                            <td>
                                <form method="post" asp-controller="OdemeTalimat" asp-action="FirmaSil"
                                      onsubmit="return confirm('@f.CariIsmi silinsin mi?')">
                                    <input type="hidden" name="id" value="@f.Id" />
                                    <button type="submit" class="ot-btn ot-btn-danger" style="padding:5px 12px; font-size:12px;">🗑 Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
