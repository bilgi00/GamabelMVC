
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        /* ========== A4 KÂĞ IT KONTEYNERI - NORMAL GÖRÜNÜM ========== */
        .print-container {
            width: 210mm;
            min-height: 297mm;
            max-height: 98vh;
            padding: 10mm;
            background: white;
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: auto;
            margin: auto;
            box-sizing: border-box;
        }

        .print-content {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 277mm;
            gap: 10px;
        }

        /* Tablo konteyner - sayfa içinde kalmalı */
        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            margin: 0 !important;
            padding: 0 !important;
        }

        /* ========== RENKLENDİRME VE STILLER ========== */
        .bg-print-primary {
            background-color: #0d6efd;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .text-print-white {
            color: white;
        }

        .bg-print-light {
            background-color: #f8f9fa;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .print-color-exact {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .table-print {
            table-layout: fixed;
            width: 100%;
            font-size: 0.9rem;
        }

        /* Başlık alt çizgisi - mavi */
        .text-center.border-bottom {
            border-bottom: 3px solid #0d6efd !important;
        }

        /* ========== YAZDIRMA STİLLERİ ========== */
        @@page {
            size: A4 portrait;
            margin: 15mm 15mm 15mm 15mm;
        }

        @@media print {
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            /* Genel ayarlar */
            html, body {
                width: 100%;
                height: 100%;
                margin: 0;
                padding: 0;
                background: white;
                display: flex;
                flex-direction: column;
            }

            body {
                display: flex;
                flex-direction: column;
            }

            /* Yazdırmayan öğeler */
            .no-print {
                display: none !important;
            }

            /* Sayfa konteyneri */
            .print-container {
                width: 100% !important;
                height: 100% !important;
                min-height: 100% !important;
                max-height: none !important;
                padding: 0 !important;
                margin: 0 !important;
                box-shadow: none !important;
                border-radius: 0 !important;
                overflow: visible !important;
                display: flex !important;
                flex-direction: column !important;
            }

            .print-content {
                display: flex !important;
                flex-direction: column !important;
                justify-content: space-between !important;
                min-height: 100% !important;
                height: 100% !important;
            }

            /* Üst kısım - tablo */
            .print-content > div:first-child {
                page-break-inside: avoid;
                flex-shrink: 0;
            }

            /* Tablo ayarları */
            .table-responsive {
                overflow: visible !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            .table-print {
                table-layout: fixed !important;
                width: 100% !important;
                font-size: 0.85rem !important;
            }

            .table-print tr {
                page-break-inside: avoid;
            }

            .table-print thead {
                display: table-header-group;
            }

            /* Renk koruma */
            .bg-print-primary {
                background-color: #0d6efd !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            .text-print-white {
                color: white !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            .bg-print-light {
                background-color: #f8f9fa !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            .print-color-exact {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }

            /* Alt kısım - SAYFA ALTINA SABİTLENECEK */
            .print-content > div:last-child {
                page-break-inside: avoid;
                margin-top: auto;
                padding-top: 0;
                border-top: none;
                flex-shrink: 0;
            }

            .mt-auto {
                margin-top: auto !important;
            }

            /* İmza alanı - sayfa kesme yok */
            .row.border-top {
                page-break-inside: avoid;
            }

            /* Alt bilgi - sayfa kesme yok */
            .row.small.text-muted {
                page-break-inside: avoid;
            }

            /* Başlık - çerçeve yok */
            .text-center.border-bottom {
                page-break-inside: avoid;
                border: none !important;
                border-bottom: 2px solid #0d6efd !important;
            }

            /* Toplam kutusu */
            .bg-light.border {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body class="d-flex justify-content-center align-items-center min-vh-100 p-2" style="background-color: #f5f5f5;">

    <button class="btn btn-primary no-print position-fixed bottom-0 end-0 m-4 rounded-pill shadow px-4 py-2" onclick="printDocument()" style="z-index: 9999;">
        <i class="fas fa-print me-2"></i> Yazdır
    </button>

    <div class="print-container">
        
        <div class="print-content">
            
            <!-- ÜST İÇERİK -->
            <div>
                
                <!-- BAŞLIK -->
                <div class="text-center border-bottom border-3 pb-3 mb-4">
                    <h2 class="fw-bold text-primary mb-1">GAMABEL YATIRIM LTD </h2>
                    <h5 class="fw-medium text-secondary">Ödeme Talimatı</h5>
                </div>

                <!-- TALİMAT NO & TARİH -->
                   <div class="bg-light rounded-1 p-1 mb-2 border-start border-1 border-primary print-color-exact">
            
             
                    <div class="row">
                        <div class="col-6">
                            <span class="fw-semibold text-secondary">Talimat No:</span>
                            <span class="fw-semibold">@Model.TalimatNo</span>
                        </div>
                        <div class="col-6 text-end">
                            <span class="fw-semibold text-secondary">Tarih:</span>
                            <span class="fw-semibold">@Model.Tarih.ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>
                </div>

                <!-- AÇIKLAMA -->
                      <p class="mb-4 ">
                    Şubenizde bulunan şirketimize ait <strong>@Model.BankaIBAN</strong> numaralı
                    hesabımızdan aşağıda bilgileri yazılı alıcılara EFT/Havale yapılmasını talep ederiz.
                </p>

                <!-- TABLO -->
                <div class="table-responsive mb-4">
                    <table class="table table-bordered table-striped table-sm align-middle table-print">
                        <colgroup>
                            <col style="width: 30px;">
                            <col style="width: 130px;">
                            <col style="width: 160px;">
                            <col style="width: 150px;">
                            <col style="width: 70px;">
                        </colgroup>

                        <thead class="bg-print-primary text-print-white">
                            <tr>
                                <th class="text-center"></th>
                                <th>Alıcı İsmi</th>
                                <th>IBAN</th>
                                <th>Açıklama</th>
                                <th class="text-end">Tutar (TL)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int sira = 1;
                            }
                            @foreach (var s in Model.Satirlar)
                            {
                                <tr>
                                    <td class="text-center fw-semibold text-secondary">@sira</td>
                                    <td style="font-size: 0.70rem;">@s.FirmaOdemeIsmi</td>
                                    <td style="font-size: 0.70rem;">@s.FirmaIBAN</td>
                                    <td style="font-size: 0.70rem;">@s.Aciklama</td>
                                    <td class="text-end fw-semibold" style="font-size: 0.70rem;">@s.Tutar.ToString("N2")</td>
                                </tr>
                                sira++;
                            }
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- ALT KISIM - SAYFA ALTINA SABİTLENECEK -->
            <div class="mt-auto">

                <!-- TOPLAM -->
                <div class="bg-light border border-2 border-primary rounded-3 p-3 mb-4 print-color-exact">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <small>
                                <i class="fas fa-calculator text-primary me-1"></i>
                                @Model.ToplamAdet Adet EFT/Havale yapılmasını ve oluşacak ücret, masraf ve
                                vergilerin <strong>@Model.BankaIBAN</strong> numaralı hesabımızdan tahsili için gereğinin
                                yapılmasını arz ederiz.
                            </small>
                        </div>
                        <div class="col-md-4 text-md-end mt-2 mt-md-0">
                            <span class="fw-bold text-primary fs-6">
                                Genel Toplam: @Model.ToplamTutar.ToString("N2") TL
                            </span>
                        </div>
                    </div>
                </div>

                <!-- İMZA ALANLARI - ÇİZGİSİZ -->
                <div class="row border-top pt-4 mb-3">
                    <div class="col-6 text-center">
                        <div class="fw-semibold text-secondary mb-5">HAZIRLAYAN</div>

                    </div>
                    <div class="col-6 text-center">
                        <div class="fw-semibold text-secondary mb-5">ONAYLAYAN</div>

                    </div>
                </div>

                <!-- ALT BİLGİ -->
                <div class="row small text-muted border-top pt-1">
                    <div class="col-4">
                        <span class="fw-semibold text-primary">FRM.01 v1</span> — Ödeme Talimatı Formu
                    </div>
                    <div class="col-4 text-center">
                        <i class="far fa-clock me-1"></i> @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
                    </div>
                    <div class="col-4 text-end">
                        <span>Sayfa 1 / 1</span>
                    </div>
                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Yazdırma fonksiyonu
        function printDocument() {
            window.print();
        }
    </script>
</body>
</html>