@{
    ViewData["Title"] = "Hızlı Mesai Girişi";
    var birimler = (ViewBag.Birimler as List<string>) ?? new List<string>();
    var personeller = (ViewBag.Personeller as List<dynamic>) ?? new List<dynamic>();
    var personelMesaiVerileri = (ViewBag.PersonelMesaiVerileri as Dictionary<int, Dictionary<string, dynamic>>) ?? new Dictionary<int, Dictionary<string, dynamic>>();
    var secilenYil = (int?)ViewBag.SecilenYil ?? DateTime.Now.Year;
    var secilenAy = (int?)ViewBag.SecilenAy ?? DateTime.Now.Month;
    var secilenBirim = (string?)ViewBag.SecilenBirim ?? "";
    var gunSayisi = (int)ViewBag.GunSayisi;
    var rol = ViewBag.Rol ?? "";
    
    var ayAdlari = new[] { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", 
                           "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
}

<!-- Bootstrap CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<style>
    .mesai-container { padding: 1rem; }
    .header-section { margin-bottom: 1rem; }
    .controls-row { box-shadow: 0 0 0 1px rgba(15,23,42,.08); }
    .control-group label { letter-spacing: .02em; }
    .nav-buttons button { min-width: 48px; }

    .mesai-table-wrapper { overflow-x: auto; background: #fff; border: 1px solid #dee2e6; border-radius: .75rem; }
    .mesai-table { width: 100%; min-width: 980px; border-collapse: collapse; }
    .mesai-table th, .mesai-table td { border: 1px solid #dee2e6; padding: .55rem .45rem; text-align: center; vertical-align: middle; }
    .mesai-table th { background: #f8fafc; color: #0f172a; font-weight: 700; position: sticky; top: 0; z-index: 3; }
    .mesai-table th.personel-name-cell, .mesai-table td.personel-name-cell { position: sticky; left: 0; z-index: 4; background: #f8fafc; text-align: left; min-width: 220px; }
    .mesai-table th.total-column-cell, .mesai-table td.total-column-cell { min-width: 84px; background: #f8fafc; }
    .mesai-table th.day-weekend, .mesai-table td.day-weekend-col { background: #eef2ff; }

    .mesai-cell { min-height: 44px; display:flex; align-items:center; justify-content:center; cursor:pointer; border-radius: .45rem; transition: background .18s ease, color .18s ease; }
    .mesai-cell.empty { color: transparent; }
    .mesai-cell.empty:hover { background: #f8fafc; color: #94a3b8; }
    .mesai-cell.warning { background: #fef3c7; color: #92400e; }
    .selected-column { background: #e0f2fe !important; }
    .month-title { min-width: 180px; display: inline-flex; justify-content: center; font-weight: 700; }

    .takvim-msg { margin-top: .75rem; min-height: 1.4rem; font-size: .95rem; color: #334155; }
    .takvim-msg.success { color: #166534; }
    .takvim-msg.error { color: #b91c1c; }

    .mesai-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); z-index: 1050; align-items: center; justify-content: center; padding: 1rem; }
    .mesai-modal { width: min(520px, 100%); background: #fff; border-radius: 1rem; box-shadow: 0 25px 60px rgba(15,23,42,.18); padding: 1.3rem; }
    .mesai-modal-grid { display: grid; gap: 1rem; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .mesai-modal-field.full-width { grid-column: span 2; }
    .mesai-modal-actions { display: flex; justify-content: flex-end; gap: .75rem; margin-top: 1rem; }
    .mesai-modal-msg { min-height: 1.2rem; margin-top: .75rem; font-size: .95rem; }
</style>

<div class="mesai-container">
    <div class="header-section">
        <h1 class="mb-3">⚡ Hızlı Mesai Girişi</h1>
        
        <div class="controls-row d-flex flex-wrap gap-3 align-items-end bg-light p-3 rounded">
            <div class="control-group d-flex flex-column gap-1">
                <label for="subeSelect" class="fw-semibold text-secondary small">Birim Seçiniz</label>
                <select id="subeSelect" class="form-select" style="min-width:200px;" onchange="birimDegistir()">
                    <option value="">-- Birim Seçiniz --</option>
                    @foreach (var birim in birimler)
                    {
                        <option value="@birim" selected="@(birim == secilenBirim)">@birim</option>
                    }
                </select>
            </div>

            <div class="control-group d-flex flex-column gap-1">
                <label class="fw-semibold text-secondary small">Ay & Yıl</label>
                <div class="nav-buttons d-flex gap-2 align-items-center">
                    <button class="btn btn-primary" onclick="ayDegistir(-1)">←</button>
                    <span class="month-title" id="monthTitle">@ayAdlari[secilenAy] @secilenYil</span>
                    <button class="btn btn-primary" onclick="ayDegistir(1)">→</button>
                </div>
            </div>
        </div>

        <div id="takvimActionMsg" class="takvim-msg"></div>
    </div>

    @if (!string.IsNullOrEmpty(secilenBirim) && personeller.Count > 0)
    {
        <div class="mesai-table-wrapper">
            <table class="mesai-table" id="mesaiTable">
                <thead>
                    <tr>
                        <th class="personel-name-cell">Personel</th>
                        @for (int gun = 1; gun <= gunSayisi; gun++)
                        {
                            var gunTarihi = new DateTime(secilenYil, secilenAy, gun);
                            var haftaSonu = gunTarihi.DayOfWeek == DayOfWeek.Saturday || gunTarihi.DayOfWeek == DayOfWeek.Sunday;
                            <th class="@(haftaSonu ? "day-weekend" : "")" data-gun="@gun" onclick="gunBaslikSec(@gun)">@gun</th>
                        }
                        <th class="total-column-cell">Toplam</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var personel in personeller)
                    {
                        <tr class="personel-row" data-personel-id="@personel.Id">
                            <td class="personel-name-cell">@personel.AdSoyad</td>
                            @for (int gun = 1; gun <= gunSayisi; gun++)
                            {
                                var gunTarihi = new DateTime(secilenYil, secilenAy, gun);
                                var haftaSonu = gunTarihi.DayOfWeek == DayOfWeek.Saturday || gunTarihi.DayOfWeek == DayOfWeek.Sunday;
                                var haftaSonuClass = haftaSonu ? "day-weekend-col" : "";

                                if (personelMesaiVerileri.ContainsKey(personel.Id) && 
                                    personelMesaiVerileri[personel.Id].ContainsKey(gun.ToString()))
                                {
                                    var mesai = personelMesaiVerileri[personel.Id][gun.ToString()];
                                    
                                    var saatStr = mesai.ToplamSaat.ToString();
                                    
                                    // ✅ DÜZELTİLDİ: out decimal s kullanıldı
                                    decimal saat = 0m;
                                    if (decimal.TryParse(saatStr, System.Globalization.NumberStyles.Any, 
                                        System.Globalization.CultureInfo.InvariantCulture, out decimal s))
                                    {
                                        saat = s;
                                    }
                                    
                                    // Formatla
                                    int saatInt = (int)Math.Floor(saat);
                                    int dakika = (int)Math.Round((saat - saatInt) * 60);
                                    if (dakika >= 60) { saatInt++; dakika = 0; }
                                    var kod = $"{saatInt:D2}:{dakika:D2}";
                                    var uyariSinifi = saat > 8 ? "warning" : "";
                                    
                                    var dataSaat = saat.ToString(System.Globalization.CultureInfo.InvariantCulture);

                                    <td class="@haftaSonuClass" data-gun="@gun" data-saat="@dataSaat">
                                        <div class="mesai-cell @uyariSinifi" onclick="modalAc(@personel.Id, @gun, @mesai.Id, 'edit')">
                                            @kod
                                        </div>
                                    </td>
                                }
                                else
                                {
                                    <td class="@haftaSonuClass" data-gun="@gun" data-saat="0" onclick="modalAc(@personel.Id, @gun, 0, 'new')">
                                        <div class="mesai-cell empty"></div>
                                    </td>
                                }
                            }
                            <td class="total-column-cell" data-personel-id="@personel.Id">00:00</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (!string.IsNullOrEmpty(secilenBirim))
    {
        <div class="empty-state">
            <p>Bu birimde aktif personel bulunmamaktadır.</p>
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>Lütfen bir birim seçiniz.</p>
        </div>
    }
</div>

<!-- Modal -->
<div id="mesaiModalOverlay" class="mesai-modal-overlay" onclick="modalKapat(event)">
    <div class="mesai-modal" onclick="event.stopPropagation()">
        <h3 id="mesaiModalTitle">Mesai Kaydı</h3>
        <div class="mesai-modal-grid">
            <div class="mesai-modal-field full-width">
                <label>Tarih</label>
                <input id="mesaiTarih" type="text" class="form-control" readonly />
            </div>
            <div class="mesai-modal-field">
                <label>Başlangıç</label>
                <input id="mesaiBaslangic" type="time" class="form-control" value="08:00" />
            </div>
            <div class="mesai-modal-field">
                <label>Bitiş</label>
                <input id="mesaiBitis" type="time" class="form-control" value="17:00" />
            </div>
            <div class="mesai-modal-field full-width">
                <label>Açıklama</label>
                <textarea id="mesaiAciklama" class="form-control" rows="2" placeholder="İsteğe bağlı açıklama..."></textarea>
            </div>
        </div>
        <div class="mesai-modal-actions">
            <button type="button" class="btn btn-secondary" onclick="modalKapat()">Vazgeç</button>
            <button type="button" class="btn btn-primary" onclick="kaydet()">Kaydet</button>
        </div>
        <div id="mesaiModalMsg" class="mesai-modal-msg"></div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
// ============================================================
// SABİTLER
// ============================================================
var AY_ADLARI = ['', 'Ocak', 'Subat', 'Mart', 'Nisan', 'Mayis', 'Haziran', 
                   'Temmuz', 'Agustos', 'Eylul', 'Ekim', 'Kasim', 'Aralik'];

var SECILEN_AY = @secilenAy;
var SECILEN_YIL = @secilenYil;

// ============================================================
// STATE
// ============================================================
var state = {
    personelId: 0,
    gun: 0,
    kayitId: 0,
    mode: 'new'
};

// ============================================================
// MESAJ
// ============================================================
function mesajGoster(text, type) {
    type = type || 'info';
    var el = document.getElementById('takvimActionMsg');
    if (!el) return;
    el.textContent = text;
    el.className = 'takvim-msg';
    if (type === 'error') el.classList.add('error');
    if (type === 'success') el.classList.add('success');
    if (type === 'info') el.style.color = '#334155';
}

// ============================================================
// FORMATLAMA
// ============================================================
function formatDakikaJS(toplamDakika) {
    if (isNaN(toplamDakika)) return '00:00';
    var s = Math.floor(toplamDakika / 60);
    var d = Math.round(toplamDakika % 60);
    if (d >= 60) { s++; d = 0; }
    return String(s).padStart(2, '0') + ':' + String(d).padStart(2, '0');
}

// ============================================================
// TABLO HESAPLAMALARI
// ============================================================
function hesaplaToplamlar() {
    var table = document.getElementById('mesaiTable');
    if (!table) return;

    var rows = table.querySelectorAll('tbody tr.personel-row');
    
    rows.forEach(function(row) {
        var toplamDakika = 0;
        var hucreler = row.querySelectorAll('td[data-saat]');
        
        hucreler.forEach(function(h) {
            var saatStr = h.getAttribute('data-saat') || '0';
            var saat = parseFloat(saatStr.replace(',', '.'));
            if (!isNaN(saat) && saat > 0) {
                toplamDakika += Math.round(saat * 60);
            }
        });

        var toplam = row.querySelector('.total-column-cell');
        if (toplam) {
            toplam.textContent = formatDakikaJS(toplamDakika);
            toplam.classList.remove('warning');
            
            var toplamSaat = toplamDakika / 60;
            if (toplamSaat > 88) {
                toplam.classList.add('warning');
                toplam.title = 'Aylık 88 saat aşıldı!';
            }
        }
    });
}

// ============================================================
// NAVIGASYON
// ============================================================
function birimDegistir() {
    var birim = document.getElementById('subeSelect').value;
    if (birim) {
        window.location.href = '/HizliMesaiGirisi/Index?birim=' + encodeURIComponent(birim) + '&yil=' + SECILEN_YIL + '&ay=' + SECILEN_AY;
    }
}

function ayDegistir(miktar) {
    var ay = SECILEN_AY + miktar;
    var yil = SECILEN_YIL;
    
    if (ay > 12) { ay = 1; yil++; }
    else if (ay < 1) { ay = 12; yil--; }
    
    var birim = document.getElementById('subeSelect').value;
    if (birim) {
        window.location.href = '/HizliMesaiGirisi/Index?birim=' + encodeURIComponent(birim) + '&yil=' + yil + '&ay=' + ay;
    }
}

function gunBaslikSec(gun) {
    markSelectedGun(gun);
    mesajGoster('Seçili gün: ' + gun + '. Herhangi bir personel hücresine tıklayın.');
}

function markSelectedGun(gun) {
    var gunlar = document.querySelectorAll('[data-gun]');
    gunlar.forEach(function(el) {
        var deger = parseInt(el.getAttribute('data-gun'), 10);
        if (deger === gun) {
            el.classList.add('selected-column');
        } else {
            el.classList.remove('selected-column');
        }
    });
}

// ============================================================
// MODAL
// ============================================================
function modalAc(personelId, gun, kayitId, mode) {
    state.personelId = personelId;
    state.gun = gun;
    state.kayitId = kayitId;
    state.mode = mode;

    markSelectedGun(gun);

    var tarih = SECILEN_YIL + '-' + String(SECILEN_AY).padStart(2, '0') + '-' + String(gun).padStart(2, '0');
    document.getElementById('mesaiTarih').value = tarih;
    document.getElementById('mesaiModalTitle').textContent = mode === 'edit' ? '✏️ Mesai Düzenle' : '➕ Yeni Mesai';
    document.getElementById('mesaiModalMsg').textContent = '';
    document.getElementById('mesaiModalMsg').className = 'mesai-modal-msg';
    document.getElementById('mesaiModalOverlay').style.display = 'flex';
}

function modalKapat(evt) {
    if (evt && evt.target && evt.target.id !== 'mesaiModalOverlay') return;
    document.getElementById('mesaiModalOverlay').style.display = 'none';
}

// ============================================================
// KAYDET
// ============================================================
async function kaydet() {
    var baslangic = document.getElementById('mesaiBaslangic').value;
    var bitis = document.getElementById('mesaiBitis').value;
    var aciklama = document.getElementById('mesaiAciklama').value.trim();
    var msg = document.getElementById('mesaiModalMsg');

    if (!baslangic || !bitis) {
        msg.textContent = 'Başlangıç ve bitiş saati zorunludur.';
        msg.className = 'mesai-modal-msg error';
        return;
    }

    var basArray = baslangic.split(':');
    var bitArray = bitis.split(':');
    if (basArray.length !== 2 || bitArray.length !== 2) {
        msg.textContent = 'Geçerli saat formatı giriniz (HH:MM).';
        msg.className = 'mesai-modal-msg error';
        return;
    }

    var payload = {
        personelId: state.personelId,
        tarih: document.getElementById('mesaiTarih').value,
        baslangicSaati: baslangic,
        bitisSaati: bitis,
        notlar: aciklama
    };

    try {
        var endpoint = state.mode === 'edit' 
            ? '/HizliMesaiGirisi/Guncelle' 
            : '/HizliMesaiGirisi/KayitEkle';
            
        var body = state.mode === 'edit'
            ? { id: state.kayitId, baslangicSaati: baslangic, bitisSaati: bitis, notlar: aciklama }
            : payload;

        var response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });

        if (!response.ok) {
            var text = await response.text();
            msg.textContent = text || 'Hata oluştu.';
            msg.className = 'mesai-modal-msg error';
            return;
        }

        modalKapat();
        mesajGoster('✅ Kayıt başarılı, sayfa yenileniyor...', 'success');
        setTimeout(function() { window.location.reload(); }, 500);
    } catch (err) {
        msg.textContent = 'Sunucu bağlantı hatası: ' + err.message;
        msg.className = 'mesai-modal-msg error';
    }
}

// ============================================================
// BAŞLAT
// ============================================================
document.addEventListener('DOMContentLoaded', function() {
    hesaplaToplamlar();
});
</script>