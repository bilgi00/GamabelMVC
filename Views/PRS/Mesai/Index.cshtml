    window.printBirimPdf = printBirimPdf;
    window.printPersonelPdf = printPersonelPdf;

    window.guvenliYazdir = function(kaynak) {
        if (kaynak === 'Personel') {
            printPersonelPdf();
            return;
        }
        printBirimPdf();
    };

