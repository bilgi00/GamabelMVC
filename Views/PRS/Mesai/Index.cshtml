    function yazdirmaAlaniIleBas(pdfDiv) {
        var container = document.createElement('div');
        container.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;background:white;overflow:auto;';
        container.appendChild(pdfDiv);
        document.body.appendChild(container);

        var oncekiOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';

        var temizle = function() {
            if (container && container.parentNode) {
                container.parentNode.removeChild(container);
            }
            document.body.style.overflow = oncekiOverflow;
            window.onafterprint = null;
        };

        window.onafterprint = temizle;
        setTimeout(function() {
            window.print();
            setTimeout(temizle, 1200);
        }, 250);
    }

    function printBirimPdf() {
        try {
            if (!mesaiKayitlari || mesaiKayitlari.length === 0) {
                showToast('Yazdırılacak veri yok', 'warning');
                return;
            }
            var pdfDiv = renderMesaiPdfBirim();
            yazdirmaAlaniIleBas(pdfDiv);
        } catch (e) {
            showToast('Birim PDF hazırlanamadı', 'error');
        }
    }

    function printPersonelPdf() {
        try {
            if (!mesaiKayitlari || mesaiKayitlari.length === 0) {
