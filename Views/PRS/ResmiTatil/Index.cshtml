@model List<Dictionary<string, object?>>
@{
    ViewData["Title"] = "KKTC Resmi Tatiller";
    Layout = "_Layout";
}

<div class="container-fluid px-0">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
        <div>
            <h4 class="fw-bold text-primary m-0">
                <i class="fas fa-calendar-alt me-2"></i>KKTC Resmi Tatiller
            </h4>
            <p class="text-muted small m-0">Tüm resmi tatil günlerini görüntüleyin</p>
        </div>
        @if (Model != null)
        {
            <span class="badge bg-light text-dark border">
                <i class="fas fa-list me-1"></i> @Model.Count kayıt
            </span>
        }
    </div>

    <!-- Error Alert -->
    @if (ViewBag.Hata != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> <strong>Hata:</strong> @ViewBag.Hata
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Holidays Table -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-2 px-3 border-bottom">
                <h5 class="mb-0 fw-semibold text-primary">
                    <i class="fas fa-list me-2"></i>Tatil Günleri
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width:45px;">#</th>
                                <th>Tatil Adı</th>
                                <th class="text-center" style="width:100px;">Tarih</th>
                                <th class="text-center" style="width:70px;">Gün</th>
                                <th class="text-center" style="width:80px;">Türü</th>
                                <th class="text-center" style="width:70px;">Gün No</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model)
                            {
                                var tarih = (DateTime)t["TatilTarihi"]!;
                                var tur = t["TatilTuru"]?.ToString() ?? "";
                                var badgeClass = tur.ToLower() switch
                                {
                                    "dini" => "bg-success",
                                    "ulusal" => "bg-primary",
                                    "resmi" => "bg-info",
                                    _ => "bg-secondary"
                                };
                                <tr>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">@t["Id"]</span>
                                    </td>
                                    <td class="fw-semibold">@t["TatilAdi"]</td>
                                    <td class="text-center text-muted small">@tarih.ToString("dd.MM.yyyy")</td>
                                    <td class="text-center text-muted small fst-italic">@t["GunAdi"]</td>
                                    <td class="text-center">
                                        <span class="badge @badgeClass">@tur</span>
                                    </td>
                                    <td class="text-center text-muted small">@(t["KacinciGun"] ?? "-")</td>
                                    <td class="text-muted small">@(t["Aciklama"] ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Empty State -->
    @if (Model == null || Model.Count == 0)
    {
        if (ViewBag.Hata == null)
        {
            <div class="alert alert-info border-0" role="alert">
                <i class="fas fa-info-circle me-2"></i> Henüz kayıtlı resmi tatil bulunmuyor.
            </div>
        }
    }

    <!-- Navigation -->
    <div class="mt-3">
        <a href="/Home/Index" class="btn btn-light border">
            <i class="fas fa-arrow-left me-1"></i> Ana Sayfaya Dön
        </a>
    </div>

</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/your-kit-code.js" crossorigin="anonymous"></script>
}