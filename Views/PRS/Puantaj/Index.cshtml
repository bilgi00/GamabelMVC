@{
    ViewData["Title"] = "Puantaj Takvimi";
    Layout = "_Layout";
}

<style>
    /* ========== ANA KONTEYNER ========== */
    .puantaj-wrapper {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        width: 100%;
        margin: 0 auto;
    }
    .puantaj-header {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 18px 24px;
    }
    .puantaj-header h1 {
        font-size: 22px;
        margin-bottom: 4px;
        font-weight: 600;
    }
    .puantaj-header p {
        opacity: 0.85;
        font-size: 13px;
        margin: 0;
    }

    /* ========== KONTROLLER ========== */
    .controls {
        padding: 14px 20px;
        background: #f8fafc;
        border-bottom: 1px solid #e9edf4;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        justify-content: space-between;
    }
    .controls .form-select,
    .controls .form-control {
        border-radius: 8px;
        border: 1px solid #d1d9e6;
        font-size: 13px;
        padding: 6px 12px;
        background: white;
        min-width: 100px;
    }
    .controls .form-select:focus,
    .controls .form-control:focus {
        border-color: #2a5298;
        box-shadow: 0 0 0 3px rgba(42,82,152,0.12);
    }
    .btn-puantaj {
        border-radius: 8px;
        padding: 6px 16px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        transition: all 0.2s;
        cursor: pointer;
        white-space: nowrap;
    }
    .btn-puantaj:hover {
        transform: translateY(-1px);
        opacity: 0.92;
    }
    .btn-primary-puantaj { background: #2a5298; color: white; }
    .btn-success-puantaj { background: #198754; color: white; }
    .btn-info-puantaj { background: #0dcaf0; color: #212529; }
    .btn-warning-puantaj { background: #fd7e14; color: white; }
    .btn-secondary-puantaj { background: #6c757d; color: white; }
    .btn-outline-puantaj { background: transparent; border: 1px solid #d1d9e6; color: #1e293b; }

    .date-controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .date-controls .form-select { width: auto; }
    .action-buttons { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

    .birim-badge {
        background: #e9edf4;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        color: #1e293b;
    }

    /* ========== LEGEND ========== */
    .legend {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        padding: 8px 0;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-weight: 500;
        color: #1e293b;
    }
    .legend-color {
        width: 20px;
        height: 20px;
        border-radius: 4px;
        border: 1px solid rgba(0,0,0,0.06);
    }
    .legend-color.lx { background: #d4edda; }
    .legend-color.li { background: #fff3cd; }
    .legend-color.lgi { background: #ffe5d0; }
    .legend-color.lch { background: #d1f7e9; }
    .legend-color.lv { background: #e2d9f3; }
    .legend-color.loz { background: #f8d7e6; }
    .legend-color.lh { background: #f8d7da; }

    .btn-legend-toggle {
        background: transparent;
        border: 1px solid #d1d9e6;
        border-radius: 8px;
        padding: 4px 14px;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
        color: #1e293b;
    }
    .btn-legend-toggle:hover { background: #e9edf4; }

    /* ========== TABLO KONTEYNERİ ========== */
    .table-wrapper {
        overflow: auto;
        padding: 0 12px 12px 12px;
        max-height: 75vh;
        position: relative;
    }
    .table-wrapper::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    .table-wrapper::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 4px;
    }
    .table-wrapper::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }
    .table-wrapper::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }

    /* ========== TABLO ========== */
    .puantaj-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 12px;
        table-layout: fixed;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        overflow: hidden;
    }

    /* Sütun Genişlikleri */
    .puantaj-table .col-personel { width: 260px; min-width: 200px; max-width: 280px; }
    .puantaj-table .col-gun { width: 36px; min-width: 32px; max-width: 40px; }
    .puantaj-table .col-sayac { width: 50px; min-width: 44px; max-width: 56px; }
    .puantaj-table .col-hakkedis { width: 80px; min-width: 70px; max-width: 90px; }

    /* Başlık */
    .puantaj-table thead th {
        background: #f1f5f9;
        color: #1e293b;
        font-weight: 600;
        font-size: 11px;
        text-align: center;
        padding: 6px 2px;
        border-bottom: 2px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 20;
        white-space: nowrap;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .puantaj-table thead th:last-child { border-right: none; }

    /* Hücreler */
    .puantaj-table tbody td {
        padding: 2px 1px;
        text-align: center;
        border-bottom: 1px solid #e9edf4;
        border-right: 1px solid #e9edf4;
        font-size: 12px;
        font-weight: 500;
        vertical-align: middle;
        transition: background 0.15s;
    }
    .puantaj-table tbody td:last-child { border-right: none; }

    /* Personel Sütunu - Sticky */
    .puantaj-table .col-personel-sticky {
        position: sticky;
        left: 0;
        z-index: 10;
        background: white;
        box-shadow: 2px 0 6px rgba(0,0,0,0.04);
        text-align: left !important;
        padding-left: 12px !important;
        font-weight: 500;
        font-size: 12px;
        color: #1e293b;
        border-right: 2px solid #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 260px;
    }

    /* Satır hover */
    .puantaj-table tbody tr:hover td {
        background-color: #f1f5f9 !important;
    }
    .puantaj-table tbody tr:hover .col-personel-sticky {
        background-color: #f1f5f9 !important;
    }

    /* Çift satır renkleri */
    .puantaj-table tbody tr:nth-child(even) td {
        background-color: #fafcfd;
    }
    .puantaj-table tbody tr:nth-child(even) .col-personel-sticky {
        background-color: #fafcfd;
    }

    /* ========== DURUM RENKLERİ ========== */
    .durum-cell { cursor: pointer; transition: all 0.15s; font-weight: 600; border-radius: 2px; }
    .durum-cell:hover { transform: scale(1.08); box-shadow: 0 2px 8px rgba(0,0,0,0.12); z-index: 5; position: relative; }
    .durum-cell:active { transform: scale(0.92); }

    .durum-x { background: #d4edda; color: #155724; }
    .durum-i { background: #fff3cd; color: #856404; }
    .durum-gi { background: #ffe5d0; color: #b85c00; }
    .durum-ch { background: #d1f7e9; color: #0b5e42; }
    .durum-vi { background: #e2d9f3; color: #4a2f8d; }
    .durum-oi { background: #f8d7e6; color: #a12a6e; }
    .durum-h { background: #f8d7da; color: #721c24; }

    /* Hafta Sonu */
    .durum-cell.weekend { opacity: 0.6; }
    .puantaj-table thead th.weekend { background: #e91e63; color: white; }

    /* Resmi Tatil */
    .durum-cell.tatil {
        border: 2px solid #dc3545 !important;
        position: relative;
    }
    .durum-cell.tatil::after {
        content: "🎌";
        position: absolute;
        top: -4px;
        right: -4px;
        font-size: 8px;
    }
    .puantaj-table thead th.tatil {
        background: #dc3545 !important;
        color: white !important;
    }

    /* Bugün sütunu */
    .puantaj-table .today-col {
        box-shadow: inset 0 2px 0 #ffc107, inset 0 -2px 0 #ffc107;
        background: rgba(255,193,7,0.06);
    }
    .puantaj-table thead th.today-col {
        background: #2a5298 !important;
        color: white !important;
        box-shadow: inset 0 2px 0 #ffc107, inset 0 -2px 0 #ffc107;
    }

    /* ========== SAYAÇ ve HAKEDİŞ ========== */
    .total-cell {
        background: #f1f5f9 !important;
        font-weight: 600;
        color: #1e293b;
    }
    .hakkedis-cell {
        font-weight: 700;
        font-size: 13px;
    }
    .hakkedis-good { background: #d4edda !important; color: #155724 !important; }
    .hakkedis-mid { background: #fff3cd !important; color: #856404 !important; }
    .hakkedis-low { background: #f8d7da !important; color: #721c24 !important; }

    /* ========== FOOTER ========== */
    .footer {
        padding: 12px 20px;
        background: #f8fafc;
        border-top: 1px solid #e9edf4;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        color: #64748b;
        flex-wrap: wrap;
        gap: 8px;
    }
    .auto-save-status {
        background: #e9edf4;
        padding: 2px 12px;
        border-radius: 12px;
        font-size: 11px;
        color: #475569;
    }
    .auto-save-status.active {
        background: #d4edda;
        color: #155724;
    }

    /* ========== MODAL ========== */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }
    .modal-overlay.active { display: flex; }
    .modal-content {
        background: white;
        border-radius: 16px;
        padding: 28px 32px;
        max-width: 480px;
        width: 92%;
        max-height: 90vh;
        overflow-y: auto;
        animation: modalSlideUp 0.25s ease;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    @*@keyframes modalSlideUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }*@
    .modal-content h3 { margin-bottom: 12px; font-weight: 600; color: #1e293b; font-size: 18px; }
    .modal-content .form-label { font-weight: 600; color: #475569; font-size: 13px; }
    .modal-content .form-select,
    .modal-content .form-control {
        border-radius: 8px;
        border: 1px solid #d1d9e6;
        font-size: 13px;
    }
    .modal-content .form-select:focus,
    .modal-content .form-control:focus {
        border-color: #2a5298;
        box-shadow: 0 0 0 3px rgba(42,82,152,0.12);
    }
    .modal-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 16px;
    }
    .modal-actions button { padding: 8px 24px; border-radius: 8px; border: none; font-weight: 500; cursor: pointer; transition: all 0.2s; }
    .modal-actions .btn-cancel { background: #e9edf4; color: #475569; }
    .modal-actions .btn-cancel:hover { background: #d1d9e6; }
    .modal-actions .btn-save-modal { background: #198754; color: white; }
    .modal-actions .btn-save-modal:hover { opacity: 0.9; }

    /* ========== TOAST ========== */
    .toast-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 99999;
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-width: 380px;
    }
    .toast-item {
        background: white;
        border-radius: 10px;
        padding: 12px 18px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 500;
        animation: slideIn 0.3s ease;
        border-left: 4px solid #2a5298;
    }
    .toast-item.success { border-left-color: #198754; }
    .toast-item.error { border-left-color: #dc3545; }
    .toast-item.warning { border-left-color: #ffc107; }
    .toast-item.info { border-left-color: #0dcaf0; }
    @*@keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }*@
    @*@keyframes fadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
    }*@

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 992px) {
        .controls { flex-direction: column; align-items: stretch; gap: 10px; }
        .date-controls { justify-content: center; flex-wrap: wrap; }
        .action-buttons { justify-content: center; }
        .legend { justify-content: center; }
        .puantaj-table .col-personel { width: 160px; min-width: 120px; max-width: 180px; }
        .puantaj-table .col-gun { width: 30px; min-width: 26px; max-width: 34px; }
        .puantaj-table .col-sayac { width: 40px; min-width: 36px; max-width: 44px; }
        .puantaj-table .col-hakkedis { width: 60px; min-width: 52px; max-width: 68px; }
        .puantaj-table .col-personel-sticky { max-width: 160px; font-size: 11px; padding-left: 8px !important; }
        .puantaj-table thead th { font-size: 10px; padding: 4px 1px; }
        .puantaj-table tbody td { font-size: 11px; padding: 1px; }
    }
    @@media (max-width: 576px) {
        .puantaj-header h1 { font-size: 17px; }
        .puantaj-header p { font-size: 12px; }
        .controls { padding: 10px 12px; }
        .puantaj-table .col-personel { width: 100px; min-width: 80px; max-width: 120px; }
        .puantaj-table .col-gun { width: 26px; min-width: 22px; max-width: 30px; }
        .puantaj-table .col-sayac { width: 34px; min-width: 30px; max-width: 38px; }
        .puantaj-table .col-hakkedis { width: 50px; min-width: 44px; max-width: 56px; }
        .puantaj-table .col-personel-sticky { max-width: 120px; font-size: 10px; padding-left: 4px !important; }
        .puantaj-table thead th { font-size: 9px; padding: 3px 1px; }
        .puantaj-table tbody td { font-size: 10px; padding: 1px; }
        .footer { flex-direction: column; text-align: center; gap: 4px; }
        .action-buttons .btn-puantaj { font-size: 11px; padding: 4px 10px; }
        .date-controls .form-select { font-size: 12px; padding: 4px 8px; min-width: 70px; }
        .modal-content { padding: 20px 16px; }
    }
</style>

<div class="puantaj-wrapper">
    <!-- HEADER -->
    <div class="puantaj-header">
        <h1><i class="fas fa-calendar-alt me-2"></i>Puantaj Takvimi</h1>
        <p>Toplu İzin Girişi | Otomatik Kaydetme | Veritabanı Entegrasyonu</p>
    </div>

    <!-- KONTROLLER -->
    <div class="controls">
        <div class="date-controls">
            <select id="yearSelect" class="form-select">
                <option value="2024">2024</option>
                <option value="2025">2025</option>
                <option value="2026" selected>2026</option>
            </select>
            <select id="monthSelect" class="form-select">
                <option value="1">Ocak</option>
                <option value="2">Şubat</option>
                <option value="3" selected>Mart</option>
                <option value="4">Nisan</option>
                <option value="5">Mayıs</option>
                <option value="6">Haziran</option>
                <option value="7">Temmuz</option>
                <option value="8">Ağustos</option>
                <option value="9">Eylül</option>
                <option value="10">Ekim</option>
                <option value="11">Kasım</option>
                <option value="12">Aralık</option>
            </select>
            <button class="btn-puantaj btn-primary-puantaj" id="loadBtn"><i class="fas fa-sync-alt me-1"></i>Yükle</button>
        </div>

        <div class="action-buttons">
            <button class="btn-puantaj btn-warning-puantaj" id="batchIzinBtn"><i class="fas fa-users me-1"></i>Toplu İzin</button>
            <button class="btn-puantaj btn-outline-puantaj" id="autoSaveBtn"><i class="fas fa-clock me-1"></i>Oto Kayıt: Kapalı</button>
            <button class="btn-puantaj btn-success-puantaj" id="saveBtn"><i class="fas fa-save me-1"></i>Kaydet</button>
            <button class="btn-puantaj btn-info-puantaj" id="exportBtn"><i class="fas fa-file-excel me-1"></i>Dışa Aktar</button>
            <span class="birim-badge" id="birimBadge">🏢 Tüm Birimler</span>
        </div>

        <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
            <button class="btn-legend-toggle" id="legendToggleBtn">🎨 Renk Açıklamaları ▼</button>
            <div class="legend" id="legendPanel" style="display:none;">
                <div class="legend-item"><span class="legend-color lx"></span>X</div>
                <div class="legend-item"><span class="legend-color li"></span>İ</div>
                <div class="legend-item"><span class="legend-color lgi"></span>Gİ</div>
                <div class="legend-item"><span class="legend-color lch"></span>ÇH</div>
                <div class="legend-item"><span class="legend-color lv"></span>Vİ</div>
                <div class="legend-item"><span class="legend-color loz"></span>Öİ</div>
                <div class="legend-item"><span class="legend-color lh"></span>H</div>
            </div>
        </div>
    </div>

    <!-- TABLO -->
    <div class="table-wrapper">
        <table class="puantaj-table" id="puantajTable">
            <thead id="tableHeader"></thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        <span><i class="fas fa-info-circle me-1"></i>Hücreye tıklayarak düzenleyin | Klavye: X,İ,G,Ç,V,Ö,H</span>
        <span><i class="fas fa-users me-1"></i><span id="totalPersonel">0</span> personel</span>
        <span id="autoSaveStatus" class="auto-save-status">💾 Otomatik Kayıt: Kapalı</span>
    </div>
</div>

<!-- ========== MODAL ========== -->
<div id="editModal" class="modal-overlay">
    <div class="modal-content">
        <h3><i class="fas fa-edit me-2"></i>Durum Düzenle</h3>
        <p id="modalPersonelInfo" class="fw-semibold text-primary"></p>
        <p id="modalTarihInfo" class="text-muted small"></p>
        <div class="mb-3">
            <label class="form-label">Durum</label>
            <select id="modalDurum" class="form-select">
                <option value="X">✅ Çalıştı (X)</option>
                <option value="İ">🟡 Yıllık İzin (İ)</option>
                <option value="Gİ">🟠 Görev İzni (Gİ)</option>
                <option value="ÇH">🟢 Çocuk Hastalık (ÇH)</option>
                <option value="Vİ">🟣 Vefat İzni (Vİ)</option>
                <option value="Öİ">🔴 Özel İzin (Öİ)</option>
                <option value="H">🔴 Hastalık (H)</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Açıklama (opsiyonel)</label>
            <textarea id="modalAciklama" class="form-control" rows="3"></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal()">İptal</button>
            <button class="btn-save-modal" onclick="saveModal()">Kaydet</button>
        </div>
    </div>
</div>

<!-- ========== TOPLU İZİN MODAL ========== -->
<div id="batchModal" class="modal-overlay">
    <div class="modal-content">
        <h3><i class="fas fa-users me-2"></i>Toplu İzin Girişi</h3>
        <div class="mb-3">
            <label class="form-label">👥 Personel Seç (Ctrl ile çoklu)</label>
            <select id="batchPersonelSelect" class="form-select" multiple size="6"></select>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-6">
                <label class="form-label">Başlangıç</label>
                <input type="date" id="baslangicTarih" class="form-control">
            </div>
            <div class="col-6">
                <label class="form-label">Bitiş</label>
                <input type="date" id="bitisTarih" class="form-control">
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">İzin Türü</label>
            <select id="batchIzinTipi" class="form-select">
                <option value="İ">🟡 Yıllık İzin (İ)</option>
                <option value="Gİ">🟠 Görev İzni (Gİ)</option>
                <option value="ÇH">🟢 Çocuk Hastalık (ÇH)</option>
                <option value="Vİ">🟣 Vefat İzni (Vİ)</option>
                <option value="Öİ">🔴 Özel İzin (Öİ)</option>
                <option value="H">🔴 Hastalık (H)</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Açıklama</label>
            <textarea id="batchAciklama" class="form-control" rows="2" placeholder="Toplu izin açıklaması"></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeBatchModal()">İptal</button>
            <button class="btn-save-modal" onclick="saveBatchIzin()">Toplu Ekle</button>
        </div>
    </div>
</div>

<!-- ========== KİLİT POPUP ========== -->
<div id="kilitPopupOverlay" class="modal-overlay">
    <div style="background:white; border-radius:12px; padding:30px 36px; max-width:400px; width:90%; text-align:center; box-shadow:0 8px 32px rgba(0,0,0,0.3);">
        <div style="font-size:48px; margin-bottom:10px;">🔒</div>
        <h5 style="color:#dc3545; font-weight:700; margin-bottom:10px;">Ay Kilitli</h5>
        <p id="kilitPopupMesaj" style="color:#555; margin-bottom:20px;"></p>
        <button onclick="kilitPopupKapat()" style="background:#dc3545; color:white; border:none; padding:8px 32px; border-radius:6px; font-size:14px; cursor:pointer;">Tamam</button>
    </div>
</div>

<!-- ========== TOAST ========== -->
<div id="toastContainer" class="toast-container"></div>

<!-- ========== SCRIPTS ========== -->
<script src="https://kit.fontawesome.com/your-kit-code.js" crossorigin="anonymous"></script>
<script>
    // ============================================================
    // KONFIGÜRASYON
    // ============================================================
    var izinTurleri = ['İ', 'Gİ', 'ÇH', 'Vİ', 'Öİ', 'H'];
    var personeller = [];
    var calismaVerileri = {};
    var degisenler = {};
    var currentYear = 2026;
    var currentMonth = 3;
    var kullaniciRol = '@(ViewBag.Rol ?? "birim_amiri")';
    var kullaniciBirim = '@(ViewBag.KullaniciBirim ?? "")';
    var seciliBirim = kullaniciRol === 'admin' ? 'all' : kullaniciBirim;
    var autoSaveEnabled = false;
    var autoSaveTimer = null;
    var resmiTatiller = {};

    // ============================================================
    // YARDIMCI FONKSİYONLAR
    // ============================================================
    function getMonthName(m) { return ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'][m-1]; }
    function isWeekend(y, m, d) { var dt = new Date(y, m-1, d); return dt.getDay()===0 || dt.getDay()===6; }
    function getDurumClass(d) { return {'X':'x','İ':'i','Gİ':'gi','ÇH':'ch','Vİ':'vi','Öİ':'oi','H':'h'}[d]||'x'; }
    function getDurumDisplay(d) { return {'X':'X','İ':'İ','Gİ':'Gİ','ÇH':'ÇH','Vİ':'Vİ','Öİ':'Öİ','H':'H'}[d]||'X'; }
    function getPersonelAdi(pid) { var p = personeller.find(function(x){return x.id===pid;}); return p ? p.ad+' '+p.soyad : ''; }
    function getFilteredPersoneller() { return personeller; }

    function calculateHakkedis(pid) {
        var izinGunleri = 0, data = calismaVerileri[pid] || {};
        for (var g = 1; g <= 30; g++) {
            var d = data[g];
            if (d && izinTurleri.indexOf(d) >= 0) izinGunleri++;
        }
        return 30 - izinGunleri;
    }

    // ============================================================
    // KİLİT POPUP
    // ============================================================
    function showKilitPopup(msg) {
        document.getElementById('kilitPopupMesaj').textContent = msg;
        document.getElementById('kilitPopupOverlay').classList.add('active');
    }
    function kilitPopupKapat() {
        document.getElementById('kilitPopupOverlay').classList.remove('active');
    }

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(msg, type) {
        type = type || 'info';
        var c = document.getElementById('toastContainer');
        var t = document.createElement('div');
        t.className = 'toast-item ' + type;
        var icon = type==='success'?'✅':type==='error'?'❌':type==='warning'?'⚠️':'ℹ️';
        t.innerHTML = '<span>'+icon+'</span><span>'+msg+'</span>';
        c.appendChild(t);
        setTimeout(function(){ t.style.animation='fadeOut 0.3s ease'; setTimeout(function(){t.remove();},300); },3500);
    }

    // ============================================================
    // VERİ YÜKLEME
    // ============================================================
    function loadPersoneller() {
        fetch('/Puantaj/GetPersoneller?birim=' + encodeURIComponent(seciliBirim))
            .then(function(r){return r.json();})
            .then(function(data){
                if (data.hata) { showToast('Hata: '+data.hata,'error'); return; }
                personeller = data;
                loadIzinler();
            })
            .catch(function(){ showToast('Personel verisi alınamadı','error'); });
    }

    function loadIzinler() {
        fetch('/Puantaj/GetResmiTatiller?yil='+currentYear+'&ay='+currentMonth)
            .then(function(r){return r.json();})
            .then(function(tatilData){
                resmiTatiller = {};
                if (Array.isArray(tatilData)) {
                    for (var i=0; i<tatilData.length; i++) resmiTatiller[tatilData[i].gun] = tatilData[i].tatilAdi;
                }
                return fetch('/Puantaj/GetIzinler?yil='+currentYear+'&ay='+currentMonth);
            })
            .then(function(r){return r.json();})
            .then(function(data){
                if (data.hata) { showToast('Hata: '+data.hata,'error'); return; }
                calismaVerileri = {};
                for (var idx=0; idx<data.length; idx++) {
                    var iz = data[idx];
                    if (!calismaVerileri[iz.personelId]) calismaVerileri[iz.personelId] = {};
                    calismaVerileri[iz.personelId][iz.gun] = iz.izinTipi;
                    if (iz.aciklama) calismaVerileri[iz.personelId]['aciklama_'+iz.gun] = iz.aciklama;
                }
                degisenler = {};
                renderTable();
                var tatilSayisi = Object.keys(resmiTatiller).length;
                var msg = getMonthName(currentMonth)+' '+currentYear+' yüklendi';
                if (tatilSayisi > 0) msg += ' ('+tatilSayisi+' resmi tatil)';
                showToast(msg,'info');
            })
            .catch(function(){ showToast('İzin verisi alınamadı','error'); });
    }

    // ============================================================
    // KAYDET
    // ============================================================
    function saveChanges(showMsg) {
        if (Object.keys(degisenler).length === 0) {
            if (showMsg) showToast('Kaydedilecek değişiklik yok','info');
            return;
        }
        var izinler = [];
        for (var pid in degisenler) {
            for (var gun in degisenler[pid]) {
                var durum = degisenler[pid][gun];
                var aciklama = (calismaVerileri[pid] && calismaVerileri[pid]['aciklama_'+gun]) || '';
                izinler.push({
                    PersonelId: parseInt(pid),
                    Yil: currentYear,
                    Ay: currentMonth,
                    Gun: parseInt(gun),
                    IzinTipi: durum,
                    Aciklama: aciklama
                });
            }
        }
        fetch('/Puantaj/KaydetIzin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(izinler)
        })
        .then(function(r){return r.json();})
        .then(function(data){
            if (data.basarili) {
                if (showMsg) showToast('✅ ' + data.mesaj, 'success');
                degisenler = {};
            } else {
                if (data.mesaj && data.mesaj.indexOf('kilitlenmiş') > -1) {
                    showKilitPopup(data.mesaj);
                } else {
                    showToast('Hata: ' + data.mesaj, 'error');
                }
            }
        })
        .catch(function(){ showToast('Kaydetme hatası','error'); });
    }

    function updateDurum(pid, gun, yeniDurum, aciklama) {
        if (!calismaVerileri[pid]) calismaVerileri[pid] = {};
        var eski = calismaVerileri[pid][gun];
        if (eski === yeniDurum) return false;
        calismaVerileri[pid][gun] = yeniDurum;
        if (aciklama) calismaVerileri[pid]['aciklama_'+gun] = aciklama;
        if (!degisenler[pid]) degisenler[pid] = {};
        degisenler[pid][gun] = yeniDurum;
        return true;
    }

    // ============================================================
    // OTOMATİK KAYDETME
    // ============================================================
    function scheduleAutoSave() {
        if (autoSaveTimer) clearTimeout(autoSaveTimer);
        if (autoSaveEnabled && Object.keys(degisenler).length > 0) {
            autoSaveTimer = setTimeout(function(){ saveChanges(true); autoSaveTimer=null; }, 3000);
        }
    }

    function toggleAutoSave() {
        autoSaveEnabled = !autoSaveEnabled;
        var btn = document.getElementById('autoSaveBtn');
        var st = document.getElementById('autoSaveStatus');
        if (autoSaveEnabled) {
            btn.innerHTML = '<i class="fas fa-clock me-1"></i>Oto Kayıt: Açık';
            btn.className = 'btn-puantaj btn-success-puantaj';
            st.textContent = '💾 Otomatik Kayıt: Açık (3sn)';
            st.className = 'auto-save-status active';
            showToast('Otomatik kaydetme açıldı','success');
        } else {
            btn.innerHTML = '<i class="fas fa-clock me-1"></i>Oto Kayıt: Kapalı';
            btn.className = 'btn-puantaj btn-outline-puantaj';
            st.textContent = '💾 Otomatik Kayıt: Kapalı';
            st.className = 'auto-save-status';
            if (autoSaveTimer) { clearTimeout(autoSaveTimer); autoSaveTimer=null; }
            showToast('Otomatik kaydetme kapatıldı','info');
        }
    }

    // ============================================================
    // TOPLU İZİN
    // ============================================================
    function openBatchModal() {
        var sel = document.getElementById('batchPersonelSelect');
        sel.innerHTML = '';
        getFilteredPersoneller().forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.id;
            opt.textContent = p.ad + ' ' + p.soyad + ' (' + p.birim + ')';
            sel.appendChild(opt);
        });
        var defDate = currentYear + '-' + String(currentMonth).padStart(2,'0') + '-01';
        var maxDay = Math.min(30, new Date(currentYear, currentMonth, 0).getDate());
        document.getElementById('baslangicTarih').value = defDate;
        document.getElementById('bitisTarih').value = currentYear+'-'+String(currentMonth).padStart(2,'0')+'-'+String(maxDay).padStart(2,'0');
        document.getElementById('batchAciklama').value = '';
        document.getElementById('batchModal').classList.add('active');
    }

    function closeBatchModal() {
        document.getElementById('batchModal').classList.remove('active');
    }

    function saveBatchIzin() {
        var opts = document.getElementById('batchPersonelSelect').selectedOptions;
        var pids = Array.from(opts).map(function(o){return parseInt(o.value);});
        var bas = new Date(document.getElementById('baslangicTarih').value);
        var bit = new Date(document.getElementById('bitisTarih').value);
        var tip = document.getElementById('batchIzinTipi').value;
        var acik = document.getElementById('batchAciklama').value;
        if (pids.length===0) { showToast('Personel seçin','warning'); return; }
        if (isNaN(bas)||isNaN(bit)) { showToast('Geçerli tarih girin','warning'); return; }
        var eklenen = 0;
        var gunler = [];
        for (var d=new Date(bas); d<=bit; d.setDate(d.getDate()+1)) {
            if (d.getMonth()+1===currentMonth && d.getDate()>=1 && d.getDate()<=30) gunler.push(d.getDate());
        }
        pids.forEach(function(pid) {
            gunler.forEach(function(gun) {
                if (updateDurum(pid, gun, tip, acik)) eklenen++;
            });
        });
        if (eklenen>0) {
            renderTable();
            showToast(eklenen+' kayıt eklendi','success');
            if (autoSaveEnabled) scheduleAutoSave();
        } else {
            showToast('Yeni kayıt yok','info');
        }
        closeBatchModal();
    }

    // ============================================================
    // TABLO OLUŞTURMA
    // ============================================================
    function renderTable() {
        var filtered = getFilteredPersoneller();
        var gunSayisi = 30;
        var today = new Date();
        var isCurrentMonth = (currentYear === today.getFullYear() && currentMonth === (today.getMonth() + 1));
        var todayDay = today.getDate();

        // --- HEADER ---
        var hdr = '<tr><th class="col-personel" style="position:sticky;left:0;z-index:25;">Personel</th>';
        for (var i=1; i<=gunSayisi; i++) {
            var wk = isWeekend(currentYear,currentMonth,i);
            var tatilMi = resmiTatiller.hasOwnProperty(i);
            var cls = '';
            var style = '';
            var title = '';
            if (wk) cls += ' weekend';
            if (tatilMi) { cls += ' tatil'; title = ' title="'+resmiTatiller[i]+'"'; }
            if (isCurrentMonth && i === todayDay) cls += ' today-col';
            hdr += '<th class="col-gun'+cls+'"'+style+title+'>'+i+'</th>';
        }
        hdr += '<th class="col-sayac">X</th><th class="col-sayac">İ</th><th class="col-sayac">H</th><th class="col-hakkedis">Hakediş</th></tr>';
        document.getElementById('tableHeader').innerHTML = hdr;

        // --- BODY ---
        var body = '';
        filtered.forEach(function(p) {
            var tX=0, tI=0, tH=0;
            body += '<tr data-personel-id="'+p.id+'">';
            body += '<td class="col-personel-sticky">'+p.ad+' '+p.soyad+'</td>';
            for (var gun=1; gun<=gunSayisi; gun++) {
                var durum = (calismaVerileri[p.id] && calismaVerileri[p.id][gun]) || 'X';
                var cls = 'durum-' + getDurumClass(durum);
                var disp = getDurumDisplay(durum);
                if (durum==='X') tX++;
                else if (durum==='H') tH++;
                else if (izinTurleri.indexOf(durum)>=0) tI++;
                var wk = isWeekend(currentYear,currentMonth,gun);
                var tatilMi = resmiTatiller.hasOwnProperty(gun);
                var extraCls = '';
                if (wk) extraCls += ' weekend';
                if (tatilMi) extraCls += ' tatil';
                if (isCurrentMonth && gun === todayDay) extraCls += ' today-col';
                var titleAttr = tatilMi ? ' title="'+resmiTatiller[gun]+'"' : '';
                body += '<td class="durum-cell '+cls+extraCls+'" data-gun="'+gun+'" data-personel="'+p.id+'" onclick="openModal('+p.id+','+gun+',\''+durum.replace(/'/g,"\\'")+'\')"'+titleAttr+'>'+disp+'</td>';
            }
            var hak = calculateHakkedis(p.id);
            var hakCls = hak >= 28 ? 'hakkedis-good' : (hak >= 25 ? 'hakkedis-mid' : 'hakkedis-low');
            body += '<td class="total-cell col-sayac">'+tX+'</td>';
            body += '<td class="total-cell col-sayac">'+tI+'</td>';
            body += '<td class="total-cell col-sayac">'+tH+'</td>';
            body += '<td class="hakkedis-cell '+hakCls+' col-hakkedis">'+hak+'</td>';
            body += '</tr>';
        });
        document.getElementById('tableBody').innerHTML = body;
        document.getElementById('totalPersonel').innerText = filtered.length;
        document.getElementById('birimBadge').innerHTML = '🏢 '+(seciliBirim==='all'?'Tüm Birimler':seciliBirim);
    }

    // ============================================================
    // LEGEND
    // ============================================================
    function toggleLegend() {
        var panel = document.getElementById('legendPanel');
        var btn = document.getElementById('legendToggleBtn');
        if (panel.style.display === 'none') {
            panel.style.display = 'flex';
            btn.textContent = '🎨 Renk Açıklamaları ▲';
        } else {
            panel.style.display = 'none';
            btn.textContent = '🎨 Renk Açıklamaları ▼';
        }
    }

    // ============================================================
    // MODAL
    // ============================================================
    var modalPersonelId = null, modalGun = null;

    function openModal(pid, gun, cur) {
        modalPersonelId = pid;
        modalGun = gun;
        var adi = getPersonelAdi(pid);
        document.getElementById('modalPersonelInfo').textContent = '👤 ' + adi;
        document.getElementById('modalTarihInfo').textContent = '📅 ' + gun + ' ' + getMonthName(currentMonth) + ' ' + currentYear;
        document.getElementById('modalDurum').value = cur;
        document.getElementById('modalAciklama').value = (calismaVerileri[pid] && calismaVerileri[pid]['aciklama_'+gun]) || '';
        document.getElementById('editModal').classList.add('active');
    }

    function closeModal() {
        document.getElementById('editModal').classList.remove('active');
    }

    function saveModal() {
        var dur = document.getElementById('modalDurum').value;
        var acik = document.getElementById('modalAciklama').value;
        if (updateDurum(modalPersonelId, modalGun, dur, acik)) {
            renderTable();
            showToast(getPersonelAdi(modalPersonelId) + ' - ' + modalGun + ' günü ' + getDurumDisplay(dur), 'success');
            if (autoSaveEnabled) scheduleAutoSave();
        }
        closeModal();
    }

    // ============================================================
    // KLAVYE
    // ============================================================
    document.addEventListener('keydown', function(e) {
        var t = e.target;
        if (t.classList && t.classList.contains('durum-cell')) {
            var pid = parseInt(t.dataset.personel), gun = parseInt(t.dataset.gun), nd = null;
            var key = e.key.toUpperCase();
            if (key==='X') nd='X';
            else if (key==='İ'||key==='I') nd='İ';
            else if (key==='G') nd='Gİ';
            else if (key==='Ç'||key==='C') nd='ÇH';
            else if (key==='V') nd='Vİ';
            else if (key==='Ö'||key==='O') nd='Öİ';
            else if (key==='H') nd='H';
            if (nd) {
                e.preventDefault();
                if (updateDurum(pid, gun, nd)) {
                    renderTable();
                    showToast(getPersonelAdi(pid) + ' - ' + gun + ' günü ' + getDurumDisplay(nd), 'info');
                    if (autoSaveEnabled) scheduleAutoSave();
                }
            }
        }
        if (e.ctrlKey && e.key==='s') { e.preventDefault(); saveChanges(true); }
    });

    // ============================================================
    // DIŞA AKTAR
    // ============================================================
    function openCiktiPage() {
        if (Object.keys(degisenler).length > 0) saveChanges(false);
        var url = '/Puantaj/Cikti?yil='+currentYear+'&ay='+currentMonth+'&birim='+encodeURIComponent(seciliBirim);
        window.open(url, '_blank');
    }

    // ============================================================
    // OLAY DİNLEYİCİLER
    // ============================================================
    document.getElementById('loadBtn').addEventListener('click', function() {
        currentYear = parseInt(document.getElementById('yearSelect').value);
        currentMonth = parseInt(document.getElementById('monthSelect').value);
        loadPersoneller();
    });
    document.getElementById('birimSelect')?.addEventListener('change', function(e) {
        seciliBirim = e.target.value;
        loadPersoneller();
    });
    document.getElementById('saveBtn').addEventListener('click', function(){ saveChanges(true); });
    document.getElementById('exportBtn').addEventListener('click', openCiktiPage);
    document.getElementById('batchIzinBtn').addEventListener('click', openBatchModal);
    document.getElementById('autoSaveBtn').addEventListener('click', toggleAutoSave);
    document.getElementById('legendToggleBtn').addEventListener('click', toggleLegend);

    // Modalları dışarı tıklayınca kapat
    document.getElementById('editModal').addEventListener('click', function(e){ if(e.target===this) closeModal(); });
    document.getElementById('batchModal').addEventListener('click', function(e){ if(e.target===this) closeBatchModal(); });
    document.getElementById('kilitPopupOverlay').addEventListener('click', function(e){ if(e.target===this) kilitPopupKapat(); });

    // Sayfa kapanmadan kaydet
    window.addEventListener('beforeunload', function() {
        if (Object.keys(degisenler).length > 0) saveChanges(false);
    });

    // ============================================================
    // BAŞLANGIÇ
    // ============================================================
    loadPersoneller();
</script>