@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Sevkiyat Geçmişi ve Onay Süreci";
    var subeler = (ViewBag.Subeler as IEnumerable<dynamic>)?.ToList() ?? new List<dynamic>();
    var firmalar = (ViewBag.Firmalar as IEnumerable<dynamic>)?.ToList() ?? new List<dynamic>();
    var gruplar = (ViewBag.Gruplar as IEnumerable<dynamic>)?.ToList() ?? new List<dynamic>();
    var seciiliSube = ViewBag.SeciiliSube ?? "";
    var seciliFirma = ViewBag.SeciliFirma ?? "";
    var seciliGrup = ViewBag.SeciliGrup ?? "";
}

<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="container-fluid mt-4">
    <div class="row mb-4 sts-mobile-title-row align-items-center">
        <div class="col-md-8">
            <h1>📋 Sevkiyat Geçmişi ve Onay Süreci</h1>
            <p class="text-muted">Sevkiyat İşlemlerinin Durum ve Teslim Süresi Yönetimi</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Sevkiyat/SevkBekleyenEksikler" class="btn btn-outline-primary">
                📦 Sevk Bekleyen Eksikler
            </a>
        </div>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>✓ Başarılı!</strong> @TempData["Basari"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>✗ Hata!</strong> @TempData["Hata"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white fw-bold">🔍 Sevkiyat Geçmişi - Filtreleme</div>
        <div class="card-body">
            <form method="get" action="/Sevkiyat/Gecmis" id="filterForm" class="row g-3">
                <div class="col-md-3">
                    <label for="subeAdi" class="form-label">Bölüm Seçin</label>
                    <select name="subeAdi" id="subeAdi" class="form-select">
                        @if (string.IsNullOrWhiteSpace(seciiliSube))
                        {
                            <option value="" selected>Tüm Bölümler</option>
                        }
                        else
                        {
                            <option value="">Tüm Bölümler</option>
                        }
                        @foreach (var sube in subeler)
                        {
                            @if (seciiliSube == sube.Ad)
                            {
                                <option value="@sube.Ad" selected>@sube.Ad</option>
                            }
                            else
                            {
                                <option value="@sube.Ad">@sube.Ad</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="firma" class="form-label">Firma Seçin</label>
                    <select name="firma" id="firma" class="form-select">
                        @if (string.IsNullOrWhiteSpace(seciliFirma))
                        {
                            <option value="" selected>Tüm Firmalar</option>
                        }
                        else
                        {
                            <option value="">Tüm Firmalar</option>
                        }
                        @foreach (var f in firmalar)
                        {
                            @if (seciliFirma == f.Firma)
                            {
                                <option value="@f.Firma" selected>@f.Firma</option>
                            }
                            else
                            {
                                <option value="@f.Firma">@f.Firma</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="grup" class="form-label">Grup Seçin</label>
                    <select name="grup" id="grup" class="form-select">
                        @if (string.IsNullOrWhiteSpace(seciliGrup))
                        {
                            <option value="" selected>Tüm Gruplar</option>
                        }
                        else
                        {
                            <option value="">Tüm Gruplar</option>
                        }
                        @foreach (var g in gruplar)
                        {
                            @if (seciliGrup == g.Grup)
                            {
                                <option value="@g.Grup" selected>@g.Grup</option>
                            }
                            else
                            {
                                <option value="@g.Grup">@g.Grup</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <input type="hidden" name="forceRefresh" value="true" />
                    <button type="submit" class="btn btn-primary w-100">
                        📋 Listele
                    </button>
                </div>
            </form>

            <!-- Seçili Filtreler Badges -->
            <div class="mt-3">
                @if (!string.IsNullOrWhiteSpace(seciiliSube))
                {
                    <span class="badge bg-info">📍 Bölüm: <strong>@seciiliSube</strong></span>
                }
                @if (!string.IsNullOrWhiteSpace(seciliFirma))
                {
                    <span class="badge bg-info ms-2">🏢 Firma: <strong>@seciliFirma</strong></span>
                }
                @if (!string.IsNullOrWhiteSpace(seciliGrup))
                {
                    <span class="badge bg-info ms-2">📦 Grup: <strong>@seciliGrup</strong></span>
                }
            </div>
        </div>
    </div>

    @if (Model != null && Model.Cast<dynamic>().Any())
    {
        <div class="card">
            <div class="card-header bg-dark text-white fw-bold">📋 Sevkiyat Listesi</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0 sts-table-sticky sts-mobile-table">
                        <thead class="table-dark">
                            <tr>
                                <th>Ürün</th>
                                <th>Şube</th>
                                <th>Miktar</th>
                                <th>Durum</th>
                                <th>Sevk Tarihi</th>
                                <th>Onay Tarihi</th>
                                <th>Teslim Süresi</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sev in Model)
                            {
                                var durumClass = sev.Durum == "Bekliyor" ? "bg-warning text-dark"
                                    : sev.Durum == "Yolda" ? "bg-primary"
                                    : sev.Durum == "Onaylandi" ? "bg-success"
                                    : sev.Durum == "IadeEdildi" ? "bg-danger"
                                    : sev.Durum == "Silindi" ? "bg-dark"
                                    : "bg-secondary";
                                <tr>
                                    <td data-label="Ürün">@sev.UrunAdi</td>
                                    <td data-label="Şube">@sev.SubeAdi</td>
                                    <td data-label="Miktar">@sev.SevkMiktari</td>
                                    <td data-label="Durum">
                                        <span class="badge @durumClass">
                                            @sev.Durum
                                        </span>
                                    </td>
                                    <td data-label="Sevk Tarihi">@sev.SevkTarihi.ToString("dd.MM.yyyy")</td>
                                    <td data-label="Onay Tarihi">@(sev.SubeOnayTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td data-label="Teslim Süresi">
                                        @(sev.TeslimSuresiGun == null ? "-" : $"{sev.TeslimSuresiGun} gün")
                                        @if (sev.GecikmeUyarisi)
                                        {
                                            <div><span class="badge bg-danger">SLA Aşıldı</span></div>
                                        }
                                    </td>
                                    <td data-label="İşlem" class="sts-mobile-actions">
                                        @if (sev.Durum == "Yolda")
                                        {
                                            <form method="post" action="/Sevkiyat/OnayEt" style="display:inline;">
                                                <input type="hidden" name="sevkiyatId" value="@sev.Id">
                                                <input type="hidden" name="notu" value="Onaylandı">
                                                <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                                            </form>
                                            <form method="post" action="/Sevkiyat/Reddet" class="d-inline-flex ms-2 gap-1 align-items-center">
                                                <input type="hidden" name="sevkiyatId" value="@sev.Id" />
                                                <select name="neden" class="form-select form-select-sm" style="width: 180px;">
                                                    <option value="Yanlış Ürün">Yanlış Ürün</option>
                                                    <option value="Eksik Adet">Eksik Adet</option>
                                                    <option value="Hasarlı Ürün">Hasarlı Ürün</option>
                                                    <option value="Diğer">Diğer</option>
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-danger">İade Et</button>
                                            </form>
                                        }
                                        else if (sev.Durum == "Onaylandi" && !sev.FabrikayaAktarildi)
                                        {
                                            <form method="post" action="/Siparis/SevkiyattanOlustur" class="d-inline">
                                                <input type="hidden" name="sevkiyatId" value="@sev.Id" />
                                                <button type="submit" class="btn btn-sm btn-warning">Sipariş Ver</button>
                                            </form>
                                        }
                                        else if (sev.Durum == "Onaylandi" && sev.FabrikayaAktarildi)
                                        {
                                            <span class="badge bg-success">Siparişe Aktarıldı</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-4">
            <h5>ℹ️ Bilgi</h5>
            Sevkiyat kaydı bulunmuyor.
            <a href="/Eksik/TumEksikler" class="btn btn-sm btn-primary ms-2">Bekleyen Eksikleri Gör</a>
        </div>
    }
</div>
