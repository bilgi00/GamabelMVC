@{
    ViewData["Title"] = "Geçmiş Hareketler";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Geçmiş Hareketler - İşlem Logu</h1>
            <p class="text-muted">Tüm sistem değişiklikleri ve yapılan düzeltmeler</p>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Tarih</th>
                        <th>Tablo</th>
                        <th>İşlem Tipi</th>
                        <th>Yapan Kişi</th>
                        <th>Kayıt ID</th>
                        <th>Eski Değer</th>
                        <th>Yeni Değer</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hareket in Model)
                    {
                        <tr>
                            <td>@hareket.IslemTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><code>@hareket.TabloAdi</code></td>
                            <td>
                                <span class="badge bg-@(hareket.IslemTipi == "Ekle" ? "success" : hareket.IslemTipi == "Guncelle" ? "info" : hareket.IslemTipi == "Sil" ? "danger" : "warning")">
                                    @hareket.IslemTipi
                                </span>
                            </td>
                            <td>@hareket.YapanKullanici</td>
                            <td>@hareket.KayitId</td>
                            <td>
                                @if (!string.IsNullOrEmpty(hareket.EskiDeger))
                                {
                                    <small class="text-danger">@hareket.EskiDeger</small>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(hareket.YeniDeger))
                                {
                                    <small class="text-success">@hareket.YeniDeger</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Hareket logu yoktur.</div>
    }

    <div class="mt-4">
        <a href="/RaporSts/Index" class="btn btn-secondary">Raporlara Geri Dön</a>
    </div>
</div>
