@{
    ViewData["Title"] = "Raporlar";
}

<div class="container-fluid mt-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>📊 Tüm Şubelerin Eksikleri</h1>
            <p class="text-muted">Tüm zamanlardan gelen eksikler hakkında ayrıntılı istatistikler</p>
        </div>
    </div>

    @if (ViewBag.RaporData != null)
    {
        var data = ViewBag.RaporData as Dictionary<string, object>;

        <!-- Tab Navigation -->
        <ul class="nav nav-tabs mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tab-urunler" data-bs-toggle="tab" data-bs-target="#urunler" type="button" role="tab">
                    🏆 En Çok Eksik Ürünler
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab-acil" data-bs-toggle="tab" data-bs-target="#acil" type="button" role="tab">
                    🚨 Acil Siparişler
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab-trend" data-bs-toggle="tab" data-bs-target="#trend" type="button" role="tab">
                    📈 Eksik Trendi
                </button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content">
            <!-- En Çok Eksik Ürünler -->
            <div class="tab-pane fade show active" id="urunler" role="tabpanel">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">🏆 En Sık Eksik Olan Ürünler</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Ürün Adı</th>
                                        <th>Birim</th>
                                        <th class="text-center">Eksik Sayısı</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (data?["EnCokEksikUrunler"] is List<dynamic> enCokUrunler)
                                    {
                                        @foreach (var urun in enCokUrunler)
                                        {
                                            <tr>
                                                <td>@urun.UrunAdi</td>
                                                <td><span class="badge bg-light text-dark">@urun.Birim</span></td>
                                                <td class="text-center"><strong>@urun.Adet</strong></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Acil Siparişler -->
            <div class="tab-pane fade" id="acil" role="tabpanel">
                <div class="card">
                    <div class="card-header bg-danger text-white">
                        <h6 class="mb-0">🚨 Acil Dikkat Gerektiren Siparişler</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-danger">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Şube</th>
                                        <th>Ürün</th>
                                        <th>Birim</th>
                                        <th class="text-center">Miktar</th>
                                        <th class="text-center">Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (data?["AcilEksikler"] is List<dynamic> acilEksikler)
                                    {
                                        @foreach (var eksik in acilEksikler)
                                        {
                                            <tr>
                                                <td><strong>@eksik.SubeAdi</strong></td>
                                                <td>@eksik.UrunAdi</td>
                                                <td><span class="badge bg-light text-dark">@eksik.Birim</span></td>
                                                <td class="text-center"><strong class="text-danger">@eksik.Miktar</strong></td>
                                                <td class="text-center">
                                                    <span class="badge bg-warning text-dark">@eksik.Durum</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Eksik Trendi -->
            <div class="tab-pane fade" id="trend" role="tabpanel">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">📈 Haftalık Eksik Trendi</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Hafta No</th>
                                        <th class="text-center">Toplam Eksik</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (data?["EksikTrendi"] is List<dynamic> trendi)
                                    {
                                        @foreach (var hafta in trendi)
                                        {
                                            <tr>
                                                <td><strong>Hafta @hafta.HaftaNo</strong></td>
                                                <td class="text-center">
                                                    <span class="badge bg-info">@hafta.ToplamEksik</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Action Buttons -->
    <div class="mt-4 mb-3">
        <div class="d-flex flex-wrap gap-2">
            <a href="/Home/Index" class="btn btn-secondary">← Geri Dön</a>
            <a href="/RaporSts/DetailedRapor" class="btn btn-primary">🔍 Ayrıntılı Rapor</a>
            <a href="/RaporSts/GeçmisHareketler" class="btn btn-info">📋 Geçmiş Hareketler</a>
        </div>
    </div>
</div>
