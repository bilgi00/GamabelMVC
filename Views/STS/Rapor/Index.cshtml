@{
    ViewData["Title"] = "Personel Rapor";
    Layout = "_Layout";
}

<div class="mt-3 mb-3">
    <h3>Personel Durum Raporu</h3>
</div>

@if (ViewBag.Hata != null)
{
    <div class="alert alert-danger">@ViewBag.Hata</div>
}

<div class="row mb-3">
    <div class="col-md-3">
        <label for="birimSelect" class="form-label fw-bold">Birim Seçin:</label>
        <select id="birimSelect" class="form-select" @(ViewBag.Rol != "admin" ? "disabled" : "")>
            @if (ViewBag.Rol == "admin")
            {
                <option value="">-- Birim seçiniz --</option>
                <option value="__TUMU__">Tüm Personel</option>
            }
            @if (ViewBag.Birimler != null)
            {
                @foreach (string birim in ViewBag.Birimler)
                {
                    if (ViewBag.Rol != "admin")
                    {
                        @:<option value="@birim" selected>@birim</option>
                    }
                    else
                    {
                        @:<option value="@birim">@birim</option>
                    }
                }
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="yilSelect" class="form-label fw-bold">Yıl:</label>
        <select id="yilSelect" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <label for="aySelect" class="form-label fw-bold">Ay:</label>
        <select id="aySelect" class="form-select">
            <option value="1">Ocak</option><option value="2">Şubat</option><option value="3">Mart</option>
            <option value="4">Nisan</option><option value="5">Mayıs</option><option value="6">Haziran</option>
            <option value="7">Temmuz</option><option value="8">Ağustos</option><option value="9">Eylül</option>
            <option value="10">Ekim</option><option value="11">Kasım</option><option value="12">Aralık</option>
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-primary w-100" id="btnRaporYukle">Rapor Yükle</button>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-12">
        <label class="form-label fw-bold">Rapor Seçimi:</label>
        <div class="d-flex gap-4">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkStatu" checked>
                <label class="form-check-label" for="chkStatu">📊 Personel Statü Raporu</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkIzin" checked>
                <label class="form-check-label" for="chkIzin">📅 İzin Kullanan Personeller</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkMesai" checked>
                <label class="form-check-label" for="chkMesai">⏰ Mesai Yapan Personeller</label>
            </div>
        </div>
    </div>
</div>

<div id="raporContainer" style="display:none;">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0" id="birimBaslik"></h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Personel Statüsü</th>
                            <th>Toplam</th>
                        </tr>
                    </thead>
                    <tbody id="raporBody">
                    </tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td colspan="2" class="text-end">Genel Toplam</td>
                            <td id="genelToplam"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="bosUyari" class="alert alert-info" style="display:none;">
    Seçili birimde kayıtlı personel bulunmuyor.
</div>

<div id="yukleniyor" class="text-center" style="display:none;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Yükleniyor...</span>
    </div>
</div>

<!-- İzin Raporu -->
<div id="izinContainer" class="mt-4" style="display:none;">
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">📅 İzin Kullanan Personeller</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Ad Soyad</th>
                            <th>Birim</th>
                            <th>İzin Türü</th>
                            <th>Gün Sayısı</th>
                        </tr>
                    </thead>
                    <tbody id="izinBody"></tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td colspan="4" class="text-end">Toplam İzin Günü</td>
                            <td id="izinToplam"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="izinBosUyari" class="alert alert-secondary mt-4" style="display:none;">
    Bu ay izin kullanan personel bulunmuyor.
</div>

<!-- Mesai Raporu -->
<div id="mesaiContainer" class="mt-4" style="display:none;">
    <div class="card">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">⏰ Mesai Yapan Personeller</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Ad Soyad</th>
                            <th>Birim</th>
                            <th>Mesai Gün</th>
                            <th>Fiili Saat</th>
                            <th>Zam 0.1</th>
                            <th>Zam 0.5</th>
                            <th>Toplam Saat</th>
                        </tr>
                    </thead>
                    <tbody id="mesaiBody"></tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td colspan="3" class="text-end">TOPLAM</td>
                            <td id="mesaiGunToplam"></td>
                            <td id="mesaiFiiliToplam"></td>
                            <td id="mesaiZam01Toplam"></td>
                            <td id="mesaiZam05Toplam"></td>
                            <td id="mesaiSaatToplam"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="mesaiBosUyari" class="alert alert-secondary mt-4" style="display:none;">
    Bu ay mesai yapan personel bulunmuyor.
</div>

@section Scripts {
<script>
    var ayAdlari = ['','Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
    var izinTipiAdlari = {'İ':'Yıllık İzin','Gİ':'Görev İzni','ÇH':'Çocuk Hastalık','Vİ':'Vefat İzni','Öİ':'Özel İzin','H':'Hastalık'};

    // Yıl dropdown
    (function() {
        var ySel = document.getElementById('yilSelect');
        var now = new Date();
        for (var y = now.getFullYear() - 2; y <= now.getFullYear() + 1; y++) {
            var o = document.createElement('option');
            o.value = y; o.textContent = y;
            if (y === now.getFullYear()) o.selected = true;
            ySel.appendChild(o);
        }
        document.getElementById('aySelect').value = now.getMonth() + 1;
    })();

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    function tumRaporlariYukle() {
        var birim = document.getElementById('birimSelect').value;
        if (!birim) return;

        var yil = parseInt(document.getElementById('yilSelect').value);
        var ay = parseInt(document.getElementById('aySelect').value);

        var chkStatu = document.getElementById('chkStatu').checked;
        var chkIzin = document.getElementById('chkIzin').checked;
        var chkMesai = document.getElementById('chkMesai').checked;

        if (!chkStatu && !chkIzin && !chkMesai) {
            alert('Lütfen en az bir rapor seçin.');
            return;
        }

        // Tümünü gizle
        document.getElementById('raporContainer').style.display = 'none';
        document.getElementById('bosUyari').style.display = 'none';
        document.getElementById('izinContainer').style.display = 'none';
        document.getElementById('izinBosUyari').style.display = 'none';
        document.getElementById('mesaiContainer').style.display = 'none';
        document.getElementById('mesaiBosUyari').style.display = 'none';
        document.getElementById('yukleniyor').style.display = 'block';

        var bekleyen = 0;
        if (chkStatu) bekleyen++;
        if (chkIzin) bekleyen++;
        if (chkMesai) bekleyen++;

        function tamamlandi() {
            bekleyen--;
            if (bekleyen <= 0) document.getElementById('yukleniyor').style.display = 'none';
        }

        // 1) Statü raporu
        if (chkStatu) {
        fetch('/Rapor/GetStatuRapor?birim=' + encodeURIComponent(birim))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var tbody = document.getElementById('raporBody');
                tbody.innerHTML = '';
                if (data.hata) {
                    document.getElementById('bosUyari').textContent = 'Hata: ' + data.hata;
                    document.getElementById('bosUyari').style.display = 'block';
                    tamamlandi(); return;
                }
                if (data.length === 0) {
                    document.getElementById('bosUyari').textContent = 'Seçili birimde kayıtlı personel bulunmuyor.';
                    document.getElementById('bosUyari').style.display = 'block';
                    tamamlandi(); return;
                }
                var genel = 0;
                for (var i = 0; i < data.length; i++) {
                    genel += data[i].toplam;
                    var tr = document.createElement('tr');
                    tr.innerHTML = '<td>' + (i+1) + '</td><td>' + escapeHtml(data[i].statu) + '</td><td>' + data[i].toplam + '</td>';
                    tbody.appendChild(tr);
                }
                document.getElementById('birimBaslik').textContent = (birim === '__TUMU__' ? 'Tüm Personel' : birim) + ' - Personel Statü Raporu';
                document.getElementById('genelToplam').textContent = genel;
                document.getElementById('raporContainer').style.display = 'block';
                tamamlandi();
            }).catch(function() { tamamlandi(); });
        }

        // 2) İzin raporu
        if (chkIzin) {
        fetch('/Rapor/GetIzinRapor?birim=' + encodeURIComponent(birim) + '&yil=' + yil + '&ay=' + ay)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var tbody = document.getElementById('izinBody');
                tbody.innerHTML = '';
                if (data.hata || data.length === 0) {
                    document.getElementById('izinBosUyari').style.display = 'block';
                    tamamlandi(); return;
                }
                var toplam = 0;
                for (var i = 0; i < data.length; i++) {
                    toplam += data[i].gunSayisi;
                    var tipAdi = izinTipiAdlari[data[i].izinTipi] || data[i].izinTipi;
                    var tr = document.createElement('tr');
                    tr.innerHTML = '<td>' + (i+1) + '</td><td>' + escapeHtml(data[i].ad + ' ' + data[i].soyad) +
                        '</td><td>' + escapeHtml(data[i].birim) +
                        '</td><td><span class="badge bg-warning text-dark">' + escapeHtml(tipAdi) +
                        '</span></td><td>' + data[i].gunSayisi + '</td>';
                    tbody.appendChild(tr);
                }
                document.getElementById('izinToplam').textContent = toplam;
                document.getElementById('izinContainer').style.display = 'block';
                tamamlandi();
            }).catch(function() { tamamlandi(); });
        }

        // 3) Mesai raporu
        if (chkMesai) {
        fetch('/Rapor/GetMesaiRapor?birim=' + encodeURIComponent(birim) + '&yil=' + yil + '&ay=' + ay)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var tbody = document.getElementById('mesaiBody');
                tbody.innerHTML = '';
                if (data.hata || data.length === 0) {
                    document.getElementById('mesaiBosUyari').style.display = 'block';
                    tamamlandi(); return;
                }
                var tGun = 0, tFiili = 0, tZam01 = 0, tZam05 = 0, tSaat = 0;
                for (var i = 0; i < data.length; i++) {
                    var d = data[i];
                    tGun += d.mesaiGun;
                    tFiili += parseFloat(d.toplamFiili);
                    tZam01 += parseFloat(d.toplamZam01);
                    tZam05 += parseFloat(d.toplamZam05);
                    tSaat += parseFloat(d.toplamSaat);
                    var tr = document.createElement('tr');
                    tr.innerHTML = '<td>' + (i+1) + '</td><td>' + escapeHtml(d.adSoyad) +
                        '</td><td>' + escapeHtml(d.birim) +
                        '</td><td>' + d.mesaiGun +
                        '</td><td>' + parseFloat(d.toplamFiili).toFixed(1) +
                        '</td><td>' + parseFloat(d.toplamZam01).toFixed(1) +
                        '</td><td>' + parseFloat(d.toplamZam05).toFixed(1) +
                        '</td><td><strong>' + parseFloat(d.toplamSaat).toFixed(1) + '</strong></td>';
                    tbody.appendChild(tr);
                }
                document.getElementById('mesaiGunToplam').textContent = tGun;
                document.getElementById('mesaiFiiliToplam').textContent = tFiili.toFixed(1);
                document.getElementById('mesaiZam01Toplam').textContent = tZam01.toFixed(1);
                document.getElementById('mesaiZam05Toplam').textContent = tZam05.toFixed(1);
                document.getElementById('mesaiSaatToplam').textContent = tSaat.toFixed(1);
                document.getElementById('mesaiContainer').style.display = 'block';
                tamamlandi();
            }).catch(function() { tamamlandi(); });
        }
    }

    document.getElementById('btnRaporYukle').addEventListener('click', tumRaporlariYukle);

    // Birim amiri için otomatik yükle
    (function() {
        var sel = document.getElementById('birimSelect');
        if (sel.value && sel.disabled) {
            tumRaporlariYukle();
        }
    })();
</script>
}
