@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Kullanıcı Yönetimi</h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Admin/KullaniciEkle" class="btn btn-success">+ Yeni Kullanıcı Ekle</a>
        </div>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">@TempData["Basari"]</div>
    }

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">@TempData["Hata"]</div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>Şube</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kullanici in Model)
                    {
                        <tr>
                            <td>@kullanici.AdSoyad</td>
                            <td><code>@kullanici.KullaniciAdi</code></td>
                            <td>@kullanici.SubeAdi</td>
                            <td>
                                <span class="badge bg-@(kullanici.Rol == "Admin" ? "danger" : kullanici.Rol == "DepoSorumlusu" ? "warning" : "info")">
                                    @kullanici.Rol
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-@(kullanici.AktifMi ? "success" : "secondary")">
                                    @(kullanici.AktifMi ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td>
                                <a href="/Admin/KullaniciDuzenle/@kullanici.Id" class="btn btn-sm btn-warning">Düzenle</a>
                                <form method="post" action="/Admin/KullaniciSil" style="display:inline;" onsubmit="return confirm('Bu kullanıcı silinsin mi?');">
                                    <input type="hidden" name="id" value="@kullanici.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Kullanıcı yoktur.</div>
    }
</div>
