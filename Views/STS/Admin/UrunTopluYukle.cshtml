@model UrunTopluYukleResult

@{
    ViewData["Title"] = "Ürün Toplu Yükleme";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Excel ile Ürün Toplu Giriş</h1>
            <p class="text-muted">Excel eşleşmesi: B=Kod, C=Ad, AH=Barkod, E=Birim, X=Grup, AU=Kod1, AV=Kod2, AW=Kod3</p>
        </div>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>✓ Başarılı!</strong> @TempData["Basari"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">@TempData["Hata"]</div>
    }

    @if (Model != null && (Model.ExcelSatirSayisi > 0 || Model.HataliSatir > 0 || Model.UyariSatir > 0 || Model.Guncellenen > 0 || Model.EklendiBayit > 0 || Model.Degismeyen > 0 || Model.Atlandi > 0))
    {
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header @(Model.IsPreview ? "bg-warning text-dark" : "bg-success text-white") fw-bold">
                @(Model.IsPreview ? "Ön İzleme Özeti" : "Toplu Yükleme Sonucu")
                @if (!string.IsNullOrWhiteSpace(Model.SourceFileName))
                {
                    <span class="ms-2 small">(@Model.SourceFileName)</span>
                }
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100 bg-light">
                            <div class="text-muted small">Excel Ürün Sayısı</div>
                            <div class="display-6 fw-bold">@Model.ExcelSatirSayisi</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100 bg-light">
                            <div class="text-muted small">Veritabanı Ürün Sayısı</div>
                            <div class="display-6 fw-bold">@Model.MysqlUrunSayisi</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#e8f5e9;">
                            <div class="text-muted small">Yeni Eklenecek / Eklenen</div>
                            <div class="display-6 fw-bold text-success">@Model.EklendiBayit</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#e3f2fd;">
                            <div class="text-muted small">Güncellenecek / Güncellenen</div>
                            <div class="display-6 fw-bold text-primary">@Model.Guncellenen</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#f3e5f5;">
                            <div class="text-muted small">Değişmeyen</div>
                            <div class="display-6 fw-bold text-secondary">@Model.Degismeyen</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#fff8e1;">
                            <div class="text-muted small">Atlanan</div>
                            <div class="display-6 fw-bold text-warning">@Model.Atlandi</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#fff3e0;">
                            <div class="text-muted small">Uyarı</div>
                            <div class="display-6 fw-bold" style="color:#ef6c00;">@Model.UyariSatir</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#ffebee;">
                            <div class="text-muted small">Hata</div>
                            <div class="display-6 fw-bold text-danger">@Model.HataliSatir</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="border rounded p-3 h-100" style="background:#fbe9e7;">
                            <div class="text-muted small">Silinecek Veritabanı Kaydı</div>
                            <div class="display-6 fw-bold" style="color:#d84315;">@Model.SilinecekKayit</div>
                        </div>
                    </div>
                </div>

                @if (Model.IsPreview && Model.CanApply)
                {
                    <form method="post" action="/Admin/UrunTopluYukleUygula" class="mt-4">
                        <input type="hidden" name="previewToken" value="@Model.PreviewToken" />
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="deleteMissingProducts" name="deleteMissingProducts" value="true" />
                            <label class="form-check-label" for="deleteMissingProducts">
                                Ön İzleme sonrası veritabanını temizle. Excel'de bulunmayan Kod'lu ürünleri veritabanından sil.
                            </label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success" onclick="return confirm('Ön izleme uygulanacak. Veritabanı temizleme seçiliyse Excelde olmayan ürünler silinecek. Devam edilsin mi?');">Ön İzlemeyi Onayla ve Uygula</button>
                            <a href="/Admin/UrunTopluYukle" class="btn btn-outline-secondary">Yeni Dosya Seç</a>
                        </div>
                    </form>
                }
                else if (Model.IsPreview)
                {
                    <div class="alert alert-warning mt-4 mb-0">Uygulanacak yeni veya güncellenecek kayıt yok. Gerekirse dosyayı kontrol edip yeniden yükleyin.</div>
                }
            </div>
        </div>

        @if (Model.UyariSatirlar.Count > 0)
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Uyarılar (@Model.UyariSatirlar.Count satır)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-warning">
                                <tr>
                                    <th>Satır No</th>
                                    <th>Kod</th>
                                    <th>Ürün Adı</th>
                                    <th>Uyarı Nedeni</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var uyari in Model.UyariSatirlar)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@uyari.SatirNumarasi</span></td>
                                        <td>@(string.IsNullOrWhiteSpace(uyari.Kod) ? "-" : uyari.Kod)</td>
                                        <td>@(string.IsNullOrWhiteSpace(uyari.Ad) ? "-" : uyari.Ad)</td>
                                        <td><span class="badge text-dark" style="background:#ffe082;">@uyari.UyariNedeni</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (Model.GuncellenecekUrunler.Count > 0)
        {
            <div class="card mb-4 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Güncellenecek / Güncellenen Ürünler (@Model.GuncellenecekUrunler.Count kayıt)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-primary">
                                <tr>
                                    <th>Satır</th>
                                    <th>Ürün ID</th>
                                    <th>Kod</th>
                                    <th>Ürün Adı</th>
                                    <th>Birim</th>
                                    <th>Grup</th>
                                    <th>Barkod</th>
                                    <th>Değişecek Alanlar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var urun in Model.GuncellenecekUrunler)
                                {
                                    var adDegisecek = !string.Equals(urun.MevcutAd ?? string.Empty, urun.Ad ?? string.Empty, StringComparison.OrdinalIgnoreCase);
                                    var birimDegisecek = !string.Equals(urun.MevcutBirim ?? string.Empty, urun.Birim ?? string.Empty, StringComparison.OrdinalIgnoreCase);
                                    var grupDegisecek = !string.Equals(urun.MevcutGrup ?? string.Empty, urun.Grup ?? string.Empty, StringComparison.OrdinalIgnoreCase);
                                    var barkodDegisecek = urun.BarkodDegisecek;
                                    var degisenAlanlar = new List<string>();
                                    if (adDegisecek) degisenAlanlar.Add("Ad");
                                    if (birimDegisecek) degisenAlanlar.Add("Birim");
                                    if (grupDegisecek) degisenAlanlar.Add("Grup");
                                    if (barkodDegisecek) degisenAlanlar.Add("Barkod");

                                    <tr>
                                        <td><span class="badge bg-secondary">@urun.SatirNumarasi</span></td>
                                        <td>@(urun.UrunId?.ToString() ?? "-")</td>
                                        <td>@urun.Kod</td>
                                        <td>
                                            @if (adDegisecek)
                                            {
                                                <div><span class="text-muted">@urun.MevcutAd</span> <span class="mx-1">→</span> <strong>@urun.Ad</strong></div>
                                            }
                                            else
                                            {
                                                <span>@urun.Ad</span>
                                            }
                                        </td>
                                        <td>
                                            @if (birimDegisecek)
                                            {
                                                <div><span class="text-muted">@(string.IsNullOrWhiteSpace(urun.MevcutBirim) ? "-" : urun.MevcutBirim)</span> <span class="mx-1">→</span> <strong>@urun.Birim</strong></div>
                                            }
                                            else
                                            {
                                                <span>@(string.IsNullOrWhiteSpace(urun.Birim) ? "-" : urun.Birim)</span>
                                            }
                                        </td>
                                        <td>
                                            @if (grupDegisecek)
                                            {
                                                <div><span class="text-muted">@(string.IsNullOrWhiteSpace(urun.MevcutGrup) ? "-" : urun.MevcutGrup)</span> <span class="mx-1">→</span> <strong>@(string.IsNullOrWhiteSpace(urun.Grup) ? "-" : urun.Grup)</strong></div>
                                            }
                                            else
                                            {
                                                <span>@(string.IsNullOrWhiteSpace(urun.Grup) ? "-" : urun.Grup)</span>
                                            }
                                        </td>
                                        <td>
                                            @if (barkodDegisecek)
                                            {
                                                <div><span class="text-muted">@(string.IsNullOrWhiteSpace(urun.MevcutBarkod) ? "-" : urun.MevcutBarkod)</span> <span class="mx-1">→</span> <strong>@urun.Barkod</strong></div>
                                            }
                                            else
                                            {
                                                <span>@(string.IsNullOrWhiteSpace(urun.MevcutBarkod) ? "-" : urun.MevcutBarkod)</span>
                                            }
                                        </td>
                                        <td>
                                            @if (degisenAlanlar.Count > 0)
                                            {
                                                <span class="badge bg-primary">@string.Join(", ", degisenAlanlar)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (Model.IsPreview && Model.SilinecekUrunler.Count > 0)
        {
            <div class="card mb-4 border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Veritabanından Silinecek Ürünler (@Model.SilinecekUrunler.Count kayıt)</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        Bu liste, <strong>veritabanını temizle</strong> seçeneği işaretlenirse silinecek ürünleri gösterir.
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-danger">
                                <tr>
                                    <th>ID</th>
                                    <th>Kod</th>
                                    <th>Ürün Adı</th>
                                    <th>Birim</th>
                                    <th>Grup</th>
                                    <th>Barkod</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var urun in Model.SilinecekUrunler)
                                {
                                    <tr>
                                        <td>@urun.Id</td>
                                        <td>@urun.Kod</td>
                                        <td>@urun.Ad</td>
                                        <td>@(string.IsNullOrWhiteSpace(urun.Birim) ? "-" : urun.Birim)</td>
                                        <td>@(string.IsNullOrWhiteSpace(urun.Grup) ? "-" : urun.Grup)</td>
                                        <td>@(string.IsNullOrWhiteSpace(urun.Barkod) ? "-" : urun.Barkod)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (Model.HataliSatirlar.Count > 0)
        {
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Hata Yaşanan Kayıtlar (@Model.HataliSatirlar.Count satır)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Satır No</th>
                                    <th>Kod</th>
                                    <th>Ürün Adı</th>
                                    <th>Hata Nedeni</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hatali in Model.HataliSatirlar)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">@hatali.SatirNumarasi</span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(hatali.Kod) ? "-" : hatali.Kod)</td>
                                        <td>@(string.IsNullOrWhiteSpace(hatali.Ad) ? "-" : hatali.Ad)</td>
                                        <td>
                                            <span class="badge bg-danger">@hatali.HataNedeni</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Kurallar</h5>
        </div>
        <div class="card-body">
            <ul>
                <li>Kod (B sütunu) boş olamaz.</li>
                <li>Ad (C sütunu) boş olamaz.</li>
                <li>Barkod (AH sütunu), Grup (X sütunu), Kod1 (AU sütunu), Kod2 (AV sütunu), Kod3 (AW sütunu) isteğe bağlıdır.</li>
                <li><strong>Aynı Kod ve Ad varsa:</strong> Birim, Grup, Kod1, Kod2, Kod3 alanları güncellenir (Barkod hariç).</li>
                <li><strong>Kod ve Ad farklıysa:</strong> Yeni kayıt oluşturulur.</li>
                <li>Dosya içinde tekrar eden aynı kodlar atlanır.</li>
                <li>Birim (E sütunu) boşsa varsayılan olarak Adet atanır.</li>
            </ul>
        </div>
    </div>

    <form method="post" action="/Admin/UrunTopluYukle" enctype="multipart/form-data" class="card">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Excel Dosyası (.xlsx / .xls)</label>
                <input type="file" name="file" accept=".xlsx,.xls" class="form-control" required />
            </div>

            <input type="hidden" name="submitAction" value="preview" />
            <button type="submit" class="btn btn-primary">Ön İzleme Oluştur</button>
            <a href="/Admin/Urunler" class="btn btn-secondary">İptal</a>
        </div>
    </form>

    @if (Model != null && Model.RecentLogs.Count > 0)
    {
        <div class="card mt-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Son Toplu Yükleme İşlem Logları</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Tarih</th>
                                <th>İşlem</th>
                                <th>Dosya</th>
                                <th>Kullanıcı</th>
                                <th>Excel</th>
                                <th>Yeni</th>
                                <th>Güncel</th>
                                <th>Değişmeyen</th>
                                <th>Uyarı</th>
                                <th>Hata</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.RecentLogs)
                            {
                                <tr>
                                    <td>@log.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @(log.IslemTipi == "Apply" ? "bg-success" : "bg-warning text-dark")">@log.IslemTipi</span>
                                    </td>
                                    <td>@log.DosyaAdi</td>
                                    <td>@log.KullaniciAdi</td>
                                    <td>@log.ExcelSatirSayisi</td>
                                    <td>@log.EklendiBayit</td>
                                    <td>@log.Guncellenen</td>
                                    <td>@log.Degismeyen</td>
                                    <td>@log.UyariSatir</td>
                                    <td>@log.HataliSatir</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
