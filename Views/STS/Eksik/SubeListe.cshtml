@{
    ViewData["Title"] = "Sipariş Listesi";
    var rol = Context.Session.GetString("Rol") ?? "";
}

<style>
    .sts-table-sticky thead th {
        position: sticky;
        top: 0;
        z-index: 2;
    }
</style>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Sipariş Listesi</h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Eksik/Ekle" class="btn btn-success">+ Yeni Sipariş Ekle</a>
            @if (rol != "SubePersoneli")
            {
                <a href="/Eksik/TopluYukle" class="btn btn-info">📁 Excel Yükle</a>
            }
            <a href="/Eksik/Gecmis" class="btn btn-outline-secondary">🕘 Geçmiş Liste</a>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">@TempData["Hata"]</div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover sts-table-sticky">
                <thead class="table-dark">
                    <tr>
                        <th>Sipariş No</th>
                        <th>Ürün</th>
                        <th>Miktar</th>
                        <th>Acil</th>
                        <th>Not</th>
                        <th>Durum</th>
                        <th>Giriş Tarihi</th>
                        <th>Uyarı</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var eksik in Model)
                    {
                        var durumClass = eksik.Durum == "Bekliyor" ? "bg-warning text-dark"
                            : eksik.Durum == "SevkEdildi" ? "bg-primary"
                            : eksik.Durum == "Tamamlandi" ? "bg-success"
                            : "bg-secondary";
                        <tr>
                            <td>
                                @if (string.IsNullOrWhiteSpace(eksik.SiparisNo))
                                {
                                    @:"-"
                                }
                                else if (eksik.SiparisNo.Length > 8)
                                {
                                    @(eksik.SiparisNo.Substring(0, 3) + "..." + eksik.SiparisNo.Substring(eksik.SiparisNo.Length - 3))
                                }
                                else
                                {
                                    @eksik.SiparisNo
                                }
                            </td>
                            <td>@eksik.Urun?.Ad</td>
                            <td>@eksik.Miktar</td>
                            <td>@(eksik.AcilMi ? "✅ Acil" : "")</td>
                            <td>@eksik.Not</td>
                            <td>
                                <span class="badge @durumClass">
                                    @eksik.Durum
                                </span>
                            </td>
                            <td>@eksik.GirisTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (eksik.GeciktiMi)
                                {
                                    <span class="badge bg-danger">Gecikti</span>
                                }
                                @if (eksik.TekrarliMi)
                                {
                                    <span class="badge bg-warning text-dark">Stok Problemi (@eksik.TekrarHaftaSayisi hafta)</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-danger">Sil</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Son 15 günde henüz eksik kaydı yok.</div>
    }

    <div class="mt-3">
        <small class="text-muted">
            Not: Bu listede yalnızca son 15 gün içinde girilmiş eksik kayıtları gösterilmektedir.
        </small>
    </div>
</div>
