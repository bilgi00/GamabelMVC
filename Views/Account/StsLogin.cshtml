@model gamabelmvc.Models.StsLoginViewModel
@{
    ViewData["Title"] = "STS Giriş";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 200px);">
    <div style="width: 100%; max-width: 420px;">
        <div class="card shadow-lg border-0" style="background: linear-gradient(135deg, rgba(15, 118, 110, 0.03) 0%, rgba(14, 165, 233, 0.03) 100%);">
            <!-- Header -->
            <div class="card-header text-white text-center border-0" style="background: linear-gradient(135deg, #0f766e 0%, #0ea5e9 100%); padding: 32px 30px;">
                <div class="text-center mb-3" style="font-size: 40px;">📦</div>
                <h2 class="fw-bold mb-1" style="font-size: 20px;">STS SİSTEMİ</h2>
                <p class="mb-0 small" style="opacity: 0.9;">Stok Takip Sistemi Özel Giriş</p>
            </div>

            <!-- Body -->
            <div class="card-body p-4">
                <!-- Error Alert -->
                @if (ViewBag.Hata != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>❌ Hata:</strong> @ViewBag.Hata
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <!-- Login Form -->
                <form asp-action="StsLogin" method="post">
                    <div class="mb-3">
                        <label for="KullaniciAdi" class="form-label fw-semibold">👤 Kullanıcı Adı</label>
                        <input asp-for="KullaniciAdi" class="form-control form-control-lg" placeholder="STS kullanıcı adını girin" required autocomplete="username" />
                    </div>

                    <div class="mb-4">
                        <label for="Sifre" class="form-label fw-semibold">🔐 Şifre</label>
                        <input asp-for="Sifre" type="password" class="form-control form-control-lg" placeholder="STS şifresini girin" required autocomplete="current-password" />
                    </div>

                    <button type="submit" class="btn btn-lg w-100 fw-bold text-white" style="background: linear-gradient(135deg, #0f766e 0%, #0ea5e9 100%);">
                        ✓ STS Sistemine Gir
                    </button>
                </form>

                <!-- Footer -->
                <hr class="my-4" />
                <p class="text-center text-muted mb-0">
                    <a href="/Account/Login" class="text-decoration-none fw-semibold">← Personel Sistemine Dön</a>
                </p>
            </div>
        </div>
    </div>
</div>
